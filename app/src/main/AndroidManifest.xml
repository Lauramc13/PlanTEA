<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.ACCESS_NOTIFICATION_POLICY" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.GET_ACCOUNTS" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.alarm.permission.SET_ALARM"/>

    <queries>
        <package android:name="com.example.calendar" />
    </queries>

    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/AppTheme"
        android:supportsRtl="true">

        <activity
            android:name=".presentacion.actividades.CalendarioActivity"
            android:label="Calendario"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.ConfiguracionActivity"
            android:label="Preferencias"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.ManualActivity"
            android:label="Manual de usuario"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.MainActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustPan">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".presentacion.actividades.EventosActivity"
            android:label="Eventos"
            android:windowSoftInputMode="adjustPan"
            android:screenOrientation="unspecified"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.INSERT" />
                <data android:mimeType="vnd.android.cursor.dir/event" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".presentacion.actividades.EventosPlanificadorActivity"
            android:label="Crear planificación"
            android:windowSoftInputMode="adjustResize|stateUnchanged" />

        <activity
            android:name=".presentacion.actividades.CrearPlanActivity"
            android:label="Crear planificación"
            android:windowSoftInputMode="adjustResize|stateUnchanged" />
        <activity
            android:name=".presentacion.actividades.PreLoginActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.RegisterActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.MenuAvataresPlanActivity"
            android:label="Elige avatar planificador"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.MenuObjetosActivity"
            android:label="Elige avatar planificador"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.MenuAvataresTEActivity"
            android:label="Elige avatar planificador"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.ActividadActivity"
            android:label="Actividades"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.TutorialActivity"
            android:label="Tutorial"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.CreditsActivity"
            android:label="Acerca de la aplicacion"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.TraductorActivity"
            android:windowSoftInputMode="adjustPan|stateUnchanged" />
        <activity
            android:name=".presentacion.actividades.PasswordActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.PoliticaActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.SemanaActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.PlanificacionesActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.ConfiguracionPictogramasActivity"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".presentacion.actividades.MenuUserActivity"
            android:windowSoftInputMode="adjustPan" />


        <receiver android:name=".dominio.OnAlarmReceiver" />
    </application>
</manifest>