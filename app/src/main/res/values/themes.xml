        <item name="android:popupBackground">@color/background2</item>
    </style>

    <style name="ShapeableImageViewStyle">
        <item name="cornerFamily">rounded</item> <!-- Use 'rounded' for rounded corners -->
        <item name="cornerSize">50dp</item> <!-- Adjust the corner radius value as needed -->
    </style>

    <style name="cardCuaderno">
        <item name="strokeColor">@color/md_theme_light_inverseSurface</item>
        <item name="cardBackgroundColor">@color/background2</item>
    </style>

    <style name="DialogNoAnimation" parent="@android:style/Animation.Dialog">
        <item name="android:windowExitAnimation">@null</item>
    </style>

    <style name="AppTheme.CursorBubble" parent="AppTheme">
    <item name="backgroundTint">@color/md_theme_light_primary</item>
        <item name="colorAccent">@color/md_theme_light_primary</item>
    </style>

    <style name="AppTheme.SearchBar" parent="AppTheme">
        <item name="android:textColor">@color/md_theme_light_onSurface</item>
        <item name="android:textColorHint">@color/md_theme_light_onSurface</item>
        <item name="android:editTextColor">@color/md_theme_light_onSurface</item>
        <item name="queryHint">@color/md_theme_light_onSurface</item>
        <item name="colorAccent">@color/md_theme_light_primary</item>
        <item name="backgroundColor">@color/white</item>

    </style>

    <style name="backgroundEventos">
        <item name="background">@color/md_theme_light_primaryContainer</item>
    </style>

    <style name="TimePicker" parent="ThemeOverlay.MaterialComponents.TimePicker">
        <item name="colorPrimary">@color/md_theme_light_onPrimaryContainer</item>
        <item name="fontFamily">@font/montserrat_medium</item>
        <item name="materialClockStyle">@style/TimePicker.Clock</item>
        <item name="materialButtonOutlinedStyle">@style/TimePicker.Button</item>
        <item name="chipStyle">@style/TimePicker.Chip</item>
        <item name="imageButtonStyle">@style/TimePicker.ImageButton</item>
    </style>

    <style name="TimePicker.Clock" parent="Widget.MaterialComponents.TimePicker.Clock">
        <item name="clockFaceBackgroundColor">@color/background2</item>
        <item name="clockHandColor">@color/md_theme_light_primary</item>
        <item name="clockNumberTextColor">@color/md_theme_light_onPrimaryContainer</item>
    </style>

    <style name="TimePicker.Button" parent="Widget.MaterialComponents.TimePicker.Button">
        <item name="backgroundTint">@color/background2</item>
        <item name="android:textColor">@color/md_theme_light_secondary</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="TimePicker.Chip" parent="Widget.MaterialComponents.TimePicker.Display">
        <item name="chipBackgroundColor">@color/background2</item>
        <item name="android:textColor">@color/md_theme_light_onPrimaryContainer</item>
    </style>

    <style name="TimePicker.ImageButton" parent="Widget.MaterialComponents.TimePicker.ImageButton">
        <item name="iconTint">@color/background2</item>
    </style>


    <style name="calendarTheme" parent="@style/ThemeOverlay.Material3.MaterialCalendar">
        <item name="colorPrimary">@color/md_theme_light_onPrimaryContainer</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimaryContainer</item>
        <item name="android:textSize">15sp</item>
        <item name="android:background">@color/md_theme_light_primary</item>
        <item name="android:textColor">@color/md_theme_light_onPrimaryContainer</item>
        <item name="android:colorControlActivated">@color/md_theme_dark_primaryContainer</item> <!--selected day-->
        <item name="android:textColorPrimary">@color/md_theme_light_onPrimaryContainer</item> <!--days of the month-->
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">10dp</item>
        <item name="backgroundColor">@color/md_theme_dark_primaryContainer</item>
        <item name="backgroundStacked">@color/md_theme_dark_primaryContainer</item>
    </style>

