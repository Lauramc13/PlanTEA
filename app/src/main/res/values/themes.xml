    <style name="CustomSearchViewStyle" parent="Widget.AppCompat.SearchView">
        <item name="searchIcon">@drawable/ic_search_24dp</item>
        <item name="closeIcon">@drawable/ic_search_24dp</item>
    </style>

    <style name="Switches">
        <item name="track">@color/md_theme_light_primary</item>

    </style>

    <style name="cornerRadius" parent="">
        <item name="cornerFamilyTopLeft">rounded</item>
        <item name="cornerFamilyTopRight">rounded</item>
        <item name="cornerFamilyBottomLeft">rounded</item>
        <item name="cornerFamilyBottomRight">rounded</item>
        <item name="cornerSizeTopLeft">10dp</item>
