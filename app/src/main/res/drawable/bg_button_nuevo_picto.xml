<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="?shadow"/>
                </shape>
            </item>
            <item android:bottom="5dp" android:top="0dp" android:start="0dp" android:end="0dp">
                <shape android:shape="rectangle">
                    <solid android:color="?colorBG1" />
                </shape>
            </item>

        </layer-list>
    </item>
    <item android:state_enabled="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="?pizzaraFondo"/>
                </shape>
            </item>
            <item android:bottom="5dp">
                <shape android:shape="rectangle">
                    <solid android:color="?colorBG1" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>