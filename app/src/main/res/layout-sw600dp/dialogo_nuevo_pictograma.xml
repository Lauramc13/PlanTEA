            app:layout_constraintTop_toBottomOf="@+id/lbl_NuevoPicto" />-->

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/txt_Titulo"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        style="@style/customTextInputLayout"
        android:layout_marginStart="50dp"
        android:layout_marginTop="75dp"
        android:layout_marginEnd="70dp"
        android:ems="10"
        android:inputType="text"
        android:textColor="?colorOnSurface"
        android:textColorHint="?colorOnSurface"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.392"
        app:layout_constraintStart_toEndOf="@+id/img_NuevoPicto"
        app:layout_constraintTop_toBottomOf="@+id/lbl_NuevoPicto"
        app:shapeAppearance="@style/cornerRadiusLogin">

        <com.google.android.material.textfield.TextInputEditText
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="@string/lbl_datosNombre"
            style="@style/customTextInputLayout"
            android:inputType="text"
            android:textColor="?colorOnSurface" />
    </com.google.android.material.textfield.TextInputLayout>


        <Spinner
            android:id="@+id/spinner_Categorias"
            android:textColor="?colorOnSurface"
            android:layout_width="250dp"
            android:layout_height="52dp"
            android:layout_marginTop="15dp"
            android:spinnerMode="dropdown"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.398"
            android:fontFamily="@font/montserrat_regular"
            android:background="@drawable/border_spinner"
            android:popupBackground="@drawable/border_spinner"
            app:layout_constraintStart_toEndOf="@+id/img_NuevoPicto"
            app:layout_constraintTop_toBottomOf="@+id/txt_Titulo" />

        <Button
            android:id="@+id/btn_GuardarPicto"
            style="@style/Widget.Material3.Button"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="65dp"
            android:layout_marginBottom="10dp"
            android:text="@string/btn_Guardar"
            android:textSize="14sp"
            android:textColor="#203130"
            android:fontFamily="@font/montserrat_semibold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/spinner_Categorias"
            app:layout_constraintVertical_bias="0.0" />

        <ImageView
            android:id="@+id/icono_CerrarDialogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:contentDescription="Cerrar dialogo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.977"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.041"
            app:srcCompat="@drawable/ic_baseline_close_24" />

</androidx.constraintlayout.widget.ConstraintLayout>