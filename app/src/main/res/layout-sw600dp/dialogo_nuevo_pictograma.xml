<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="550dp"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login">

        <TextView
            android:id="@+id/lbl_NuevoPicto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="@string/lbl_NuevoPicto"
            android:textColor="?colorOnSurface"
            android:fontFamily="@font/montserrat_bold"
            android:textSize="22sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/img_NuevoPicto"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_marginTop="55dp"
            style="@style/colorNewPhoto"
            android:background="@drawable/ic_baseline_add_photo_alternate_128"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.155"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lbl_NuevoPicto" />

        <!--<EditText
            android:id="@+id/txt_Titulo"
            android:layout_width="260dp"
            android:layout_height="40dp"
            android:layout_marginTop="95dp"
            android:background="@drawable/fondo_texto_login"
            android:ems="10"
            android:theme="@style/AppTheme.CursorBubble"
