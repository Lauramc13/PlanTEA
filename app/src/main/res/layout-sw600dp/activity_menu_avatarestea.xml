
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?customBgColor"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:rotation="180"
        android:layout_marginEnd="-30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/svg_blob"
        app:tint="@color/seedLight"
        android:importantForAccessibility="no" />

    <ImageView
        android:id="@+id/imageView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_blob"
        app:tint="@color/seedLight"
        android:importantForAccessibility="no" />

    <TextView
        android:id="@+id/lbl_planificacion"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.7"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:text="@string/lbl_seleccionaAvatarTEA"
        android:textColor="?colorOnSurface"
        android:textSize="@dimen/title"
        android:maxLines="2"
        app:autoSizeTextType="uniform"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/lbl_planificacion2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_medium"
        android:gravity="center"
        android:maxLines="3"
        android:layout_marginTop="10dp"
        android:text="@string/elige_un_avatar_para_la_persona_que_va_a_seguir_las_planificaciones"
        android:textColor="?colorOnSurface"
        android:textSize="@dimen/titleSmall"
        app:autoSizeTextType="uniform"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lbl_planificacion"
        app:layout_constraintWidth_percent="0.8" />

    <Button
        android:id="@+id/btn_galeria"
        style="@style/Widget.Material3.Button.IconButton.Filled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:contentDescription="Boton para seleccionar foto de la galeria"
        android:fontFamily="@font/poppins_semibold"
        android:maxLines="1"
        android:text="@string/lbl_seleccionarFoto"
        android:textAllCaps="true"
        android:textColor="#203130"
        android:textSize="@dimen/button"
        app:cornerRadius="25dp"
        android:autoSizeTextType="uniform"
        app:layout_constraintBottom_toTopOf="@+id/btn_saltar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />


    <Button
        android:id="@+id/btn_saltar"
        style="@style/Widget.Material3.Button.IconButton.Outlined"
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:backgroundTint="#FFFFFF"
        android:contentDescription="Boton para saltar el paso de seleccionar avatar del planificado"
        android:fontFamily="@font/poppins_semibold"
        android:maxWidth="10dp"
        android:text="@string/lbl_saltar"
        android:textAllCaps="true"
        android:textColor="#203130"
        android:textSize="@dimen/button"
        app:cornerRadius="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:id="@+id/linearLayout3"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="end"
        app:layout_constraintBottom_toTopOf="@+id/btn_galeria"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.65"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/lbl_planificacion2"
        app:layout_constraintWidth_percent="0.6">

        <TableLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal">

            <TableRow
                android:id="@+id/row1"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    app:cardCornerRadius="20dp"
                    android:contentDescription="Opción 1 niña pelo moreno gafas"
                    android:id="@+id/avatar1nina"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_margin="15dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar1nina" />

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    android:id="@+id/avatar2nina"
                    android:contentDescription="Opción 2 niña pelo moreno"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="20dp"
                    android:layout_margin="15dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar2nina" />

                </com.google.android.material.card.MaterialCardView>

            </TableRow>

            <TableRow
                android:id="@+id/row2"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    app:cardCornerRadius="20dp"
                    android:id="@+id/avatar3nina"
                    android:contentDescription="Opción 3 niña pelo moreno"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_margin="15dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar3nina" />

                </com.google.android.material.card.MaterialCardView>


                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    app:cardCornerRadius="20dp"
                    android:id="@+id/avatar4nina"
                    android:contentDescription="Opción 4 niña pelo negro"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_margin="15dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar4nina" />

                </com.google.android.material.card.MaterialCardView>

            </TableRow>

            <TableRow
                android:id="@+id/row5"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    app:cardCornerRadius="20dp"
                    android:id="@+id/avatar5nina"
                    android:contentDescription="Opción 5 niña pelo rubio trenzas"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_margin="15dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar5nina" />

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    app:cardCornerRadius="20dp"
                    android:id="@+id/avatar1nino"
                    android:contentDescription="Opción 1 niño pelo moreno"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_margin="15dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar1nino" />

                </com.google.android.material.card.MaterialCardView>
            </TableRow>

            <TableRow
                android:id="@+id/row3"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    app:cardCornerRadius="20dp"
                    android:id="@+id/avatar2nino"
                    android:contentDescription="Opción 2 niño pelo moreno"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_margin="15dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar2nino" />

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    app:cardCornerRadius="20dp"
                    android:id="@+id/avatar3nino"
                    android:contentDescription="Opción 3 niño pelo moreno gafas"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_margin="15dp">
                    <ImageView

                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar3nino" />

                </com.google.android.material.card.MaterialCardView>

            </TableRow>

            <TableRow
                android:id="@+id/row4"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    app:cardCornerRadius="20dp"
                    android:id="@+id/avatar4nino"
                    android:contentDescription="Opción 4 niño pelo rubio gafas"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_margin="15dp">
                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar4nino" />

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:layout_weight="1"
                    android:layout_height="150dp"
                    app:cardCornerRadius="20dp"
                    android:id="@+id/avatar5nino"
                    android:contentDescription="Opción 5 niño pelo moreno"
                    app:cardElevation="0dp"

                    app:strokeColor="?color"
                    app:strokeWidth="1.5dp"
                    app:cardBackgroundColor="@color/white"
                    android:layout_margin="15dp">

                    <ImageView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        app:srcCompat="@drawable/avatar5nino" />

                </com.google.android.material.card.MaterialCardView>
            </TableRow>

        </TableLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>

