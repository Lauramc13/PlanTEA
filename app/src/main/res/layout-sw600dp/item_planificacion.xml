<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/card_plan"
    android:layout_height="wrap_content"
    app:cardCornerRadius="20dp"
    app:cardElevation="0dp"
    android:animateLayoutChanges="true"
    style="@style/items"
    app:cardUseCompatPadding="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:id="@+id/leftLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_alignParentBottom="true"
            android:layout_toStartOf="@+id/rightLayout"
            android:orientation="vertical">

            <TextView
                android:id="@+id/lbl_Planificacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:paddingBottom="11dp"
                android:fontFamily="@font/montserrat_semibold"
                android:maxLines="1"
                android:gravity="center_vertical"
                android:text="Ejemplo plan"
                android:textColor="?colorOnSurface"
                android:textSize="18sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/icon_copy"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintVertical_bias="0.5" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rightLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_alignParentTop="true"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/icon_copy"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="10dp"
                android:contentDescription="Copiar planificacion"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/icon_edit"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/svg_files"
                />

            <ImageView
                android:id="@+id/icon_edit"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="7dp"
                android:contentDescription="Editar planificacion"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/icon_delete"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/svg_edit"
                />

            <ImageView
                android:id="@+id/icon_delete"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="10dp"
                android:contentDescription="Eliminar planificacion"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.481"
                app:srcCompat="@drawable/svg_trash"
                />

        </LinearLayout>

    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
