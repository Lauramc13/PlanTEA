<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?backgroundColor"
    tools:context=".presentacion.actividades.planificador.CalendarioActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob3"
        app:tint="#F6FBF7" />

    <ImageView
        android:id="@+id/imageView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="70dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_blob" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintWidth_max="1200dp"
        app:layout_constraintHeight_max="600dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="70dp"
        app:layout_constraintHeight_percent="0.8"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.85">

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="600dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_calendario"
            android:contentDescription="Contenedor de calendario"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:contentDescription="Mes y flechas de navegación atras/delante"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/image_calendar_anterior"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Flecha mes anterior"
                    app:srcCompat="@drawable/ic_baseline_arrow_back_32" />

                <TextView
                    android:id="@+id/lbl_mes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="2"
                    android:contentDescription="Mes"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="Noviembre 2021"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="20sp" />

                <ImageView
                    android:id="@+id/image_calendar_siguiente"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:contentDescription="Flecha mes siguiente"
                    app:srcCompat="@drawable/ic_baseline_arrow_forward_32" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:contentDescription="Columna con los dias de la semana"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/lbl_lunes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Lunes"
                    android:text="@string/lbl_lunes"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/lbl_martes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Martes"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="@string/lbl_martes"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/lbl_miercoles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Miércoles"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="@string/lbl_miercoles"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/lbl_jueves"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Jueves"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="@string/lbl_jueves"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/lbl_viernes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Viernes"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="@string/lbl_viernes"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/lbl_sabado"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Sábado"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="@string/lbl_sabado"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/lbl_domingo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Domingo"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="@string/lbl_domingo"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_calendario"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never"
                android:contentDescription="Contenedor con los días del mes"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/fragment_calendario"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="50dp"
            android:background="@drawable/bg_calendario" />

    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerViewSide"
        android:name="com.example.plantea.presentacion.fragmentos.NavigationSideFragment"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>