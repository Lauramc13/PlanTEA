<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="?colorBG0"
    android:layout_height="match_parent"
    tools:context=".presentacion.actividades.RegisterActivity">



    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="1dp"
        android:baselineAligned="false">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:layout_marginTop="50dp"
            android:layout_weight="0.4">

            <ScrollView
                android:id="@+id/scrollRegister"
                android:layout_width="match_parent"
                android:layout_height="match_parent">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/iconRegister"
                        android:layout_width="77dp"
                        android:layout_height="75dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        app:layout_constraintBottom_toTopOf="@+id/textView7"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:srcCompat="@drawable/svg_register" />

                    <TextView
                        android:id="@+id/textView7"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="@string/lbl_registrarse"
                        android:textColor="?colorOnSurface"
                        android:textSize="30sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/textView8"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="25dp"
                        android:fontFamily="@font/poppins_medium"
                        android:text="@string/lbl_datosPlanificador"
                        android:textColor="?colorOnSurface"
                        android:textSize="20sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/txt_Name"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="350dp"
                        android:layout_height="60dp"
                        android:layout_marginTop="17dp"
                        android:background="@drawable/fondo_texto_login"
                        android:ems="10"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="@string/lbl_datosNombre"
                        android:inputType="text"
                        android:textColor="?colorOnSurface"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:shapeAppearance="@style/cornerRadiusLogin">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:inputType="text"
                            android:textColor="?colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/txt_Email"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="350dp"
                        android:layout_height="60dp"
                        android:layout_marginTop="17dp"
                        android:background="@drawable/fondo_texto_login"
                        android:ems="10"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="@string/lbl_email"
                        android:inputType="text"
                        android:textColor="?colorOnSurface"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/txt_Name"
                        app:layout_constraintVertical_bias="0.004"
                        app:shapeAppearance="@style/cornerRadiusLogin">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:inputType="text"
                            android:textColor="?colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/txt_UserName"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="350dp"
                        android:layout_height="60dp"
                        android:layout_marginTop="17dp"
                        android:background="@drawable/fondo_texto_login"
                        android:ems="10"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="@string/lbl_nombreUsuario"
                        android:inputType="text"
                        android:textColor="?colorOnSurface"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/txt_Name"
                        app:shapeAppearance="@style/cornerRadiusLogin">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:inputType="text"
                            android:textColor="?colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/txt_password"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="350dp"
                        android:layout_height="60dp"
                        android:layout_marginTop="17dp"
                        android:background="@drawable/fondo_texto_login"
                        android:ems="10"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="@string/lbl_contrasena"
                        android:inputType="textPassword"
                        android:textColor="?colorOnSurface"
                        app:endIconMode="password_toggle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/txt_UserName"
                        app:shapeAppearance="@style/cornerRadiusLogin">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:inputType="textPassword"
                            android:textColor="?colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/txt_password2"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="350dp"
                        android:layout_height="60dp"
                        android:layout_marginTop="17dp"
                        android:background="@drawable/fondo_texto_login"
                        android:ems="10"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="@string/lbl_datosContraseña"
                        android:inputType="textPassword"
                        android:textColor="?colorOnSurface"
                        app:endIconMode="password_toggle"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/txt_password"
                        app:layout_constraintVertical_bias="0.258"
                        app:shapeAppearance="@style/cornerRadiusLogin">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:inputType="textPassword"
                            android:textColor="?colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/check_Objeto"
                        style="@style/Widget.Material3.CompoundButton.MaterialSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="47dp"
                        android:layout_marginBottom="17dp"
                        android:fontFamily="@font/poppins_medium"
                        android:text="@string/lbl_configuracion_objeto"
                        android:textColor="?colorOnSurface"
                        android:textSize="18sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:theme="@style/Switches" />

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="68dp">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/txt_objeto"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="350dp"
                            android:layout_height="60dp"
                            android:layout_centerInParent="true"
                            android:layout_centerHorizontal="true"
                            android:background="@drawable/fondo_texto_login"
                            android:enabled="false"
                            android:fontFamily="@font/poppins_regular"
                            android:hint="@string/lbl_configuracion_objeto"
                            android:inputType="text"
                            android:textColor="?colorOnSurface"
                            app:shapeAppearance="@style/cornerRadiusLogin">

                            <com.google.android.material.textfield.TextInputEditText
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:inputType="text"
                                android:textColor="?colorOnSurface" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonAyudaActividad"
                            style="@style/Widget.Material3.Button.IconButton.Filled"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="80dp"
                            android:layout_marginTop="10dp"
                            android:layout_toRightOf="@id/txt_objeto"
                            android:gravity="center"
                            app:cornerRadius="25dp"
                            app:icon="@drawable/question_simple"
                            app:iconSize="20dp"
                            app:iconTint="#181F25" />

                        <RelativeLayout
                            android:id="@+id/relativeLayoutTooltip"
                            android:layout_width="430dp"
                            android:layout_height="68dp">

                            <TextView
                                android:id="@+id/tooltipText"
                                android:layout_width="320dp"
                                android:layout_height="wrap_content"
                                android:layout_alignParentStart="true"
                                android:layout_marginStart="106dp"
                                android:layout_marginTop="2dp"
                                android:layout_marginEnd="2dp"
                                android:layout_marginBottom="2dp"
                                android:background="@drawable/fragment_personalizado"
                                android:padding="13dp"
                                android:text="La actividad tranquilizadora representa el objeto que calma a la persona con TEA"
                                android:textColor="?colorOnSurface"
                                android:theme="@style/cards2"
                                android:visibility="gone" />

                        </RelativeLayout>

                    </RelativeLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/check_Plaificado"
                        style="@style/Widget.Material3.CompoundButton.MaterialSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginTop="47dp"
                        android:fontFamily="@font/poppins_medium"
                        android:text="@string/lbl_datosPlanificado"
                        android:textColor="?colorOnSurface"
                        android:textSize="18sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:theme="@style/Switches" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/txt_nombreplanificado"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="350dp"
                        android:layout_height="60dp"
                        android:layout_marginTop="17dp"
                        android:background="@drawable/fondo_texto_login"
                        android:ems="10"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="@string/lbl_datosNombre"
                        android:inputType="text"
                        android:textColor="?colorOnSurface"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/textView9"
                        app:layout_constraintVertical_bias="0.258"
                        app:shapeAppearance="@style/cornerRadiusLogin">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:inputType="text"
                            android:textColor="?colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <Button
                        android:id="@+id/btn_register"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="350dp"
                        android:layout_height="52dp"
                        android:layout_marginTop="35dp"
                        android:layout_marginBottom="50dp"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="@string/lbl_crearCuenta"
                        android:textColor="#203130"
                        android:textSize="14sp"
                        app:cornerRadius="10dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/txt_Password"
                        app:layout_constraintVertical_bias="0.011" />
                </LinearLayout>
            </ScrollView>

        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_weight="0.6"
            android:background="@drawable/background_register"
            android:layout_margin="10dp">
            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:srcCompat="@drawable/svg_innovation" />
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/goBackButton"
        style="@style/Widget.Material3.Button.IconButton.Filled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cornerRadius="25dp"
        app:icon="@drawable/svg_go_back"
        app:iconSize="35dp"
        app:iconTint="?colorOnSurface"
        app:backgroundTint="@color/transparent" />

</androidx.constraintlayout.widget.ConstraintLayout>