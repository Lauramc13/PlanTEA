<!-- res/layout/activity_main.xml -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_gravity="center"
    xmlns:app="http://schemas.android.com/apk/res-auto">

        <TextView
            android:id="@+id/textView19"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/temporizador"
            android:textAllCaps="false"
            android:textColor="?colorOnSecondaryContainer"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardViewReloj"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="100dp"
            app:cardBackgroundColor="@color/transparent"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView19">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/progressBar"
                    style="@style/Widget.Material3.CircularProgressIndicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:progress="100"
                    app:indicatorColor="?colorOnSecondaryContainer"
                    app:indicatorSize="150dp"
                    app:trackColor="@color/white"
                    app:trackCornerRadius="10dp"
                    app:trackThickness="10dp" />

                <TextView
                    android:id="@+id/timerTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="15dp"
                    android:layout_marginEnd="15dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="00:00"
                    android:layout_gravity="center"
                    android:textColor="?colorOnSecondaryContainer"
                    android:textSize="20sp" />
        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/startButton"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:backgroundTint="?colorOnSecondaryContainer"
            android:contentDescription="Botón reproducir lista"
            android:elevation="0dp"
            android:textColor="@color/darkGreen"
            android:textSize="20sp"
            app:cornerRadius="25dp"
            android:layout_marginTop="20dp"
            app:icon="@drawable/svg_play"
            app:iconGravity="textEnd"
            app:iconSize="25dp"
            app:iconTint="?colorOnPrimary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cardViewReloj" />
</androidx.constraintlayout.widget.ConstraintLayout>