<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?customBgColor"
    tools:context=".presentacion.actividades.planificador.CreditsActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:rotation="180"
        android:layout_marginEnd="-30dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/svg_blob"
        app:tint="@color/seedLight" />

    <ImageView
        android:id="@+id/imageView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_blob"
        app:tint="@color/seedLight" />

    <LinearLayout
        android:id="@+id/linearLayout9"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="?backgroundSplit"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/goBackButton"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_marginStart="20dp"
            android:padding="15dp"
            app:backgroundTint="?colorSecondaryContainer"
            app:cornerRadius="20dp"
            app:icon="@drawable/svg_go_back"
            app:iconSize="28dp"
            app:iconTint="?colorOnSurface" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:fontFamily="@font/montserrat_semibold"
            android:text="Acerca de la aplicación"
            android:textSize="23sp" />
    </LinearLayout>

    <com.google.android.material.divider.MaterialDivider
        android:id="@+id/materialDivider"
        android:layout_width="match_parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout9"
        android:layout_height="2dp"/>

        <ScrollView
            android:id="@+id/scrollview"
            android:layout_width="600dp"
            android:layout_height="550dp"
            android:layout_marginStart="100dp"
            android:background="@drawable/fondo_cuaderno_tiempo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout9">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/svg_info" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sobre la organización"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:textColor="?colorOnSurface"
                    android:textSize="18sp"
                    android:fontFamily="@font/montserrat_bold"/>

            </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:justificationMode="inter_word"
                    android:text="@string/str_parrafo1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:layout_marginBottom="10dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:justificationMode="inter_word"
                    android:text="@string/str_parrafo2"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginBottom="15dp"
                    android:justificationMode="inter_word"
                    android:text="@string/str_parrafo3"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/montserrat_bold"
                    android:layout_marginBottom="7dp"
                    android:text="Sobre el Grupo CHICO"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:layout_marginBottom="10dp"
                    android:justificationMode="inter_word"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="@string/str_parrafo4"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:justificationMode="inter_word"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="@string/str_parrafo5"/>
            </LinearLayout>



        </ScrollView>


    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="550dp"
        android:layout_marginStart="30dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/scrollview"
        app:layout_constraintTop_toBottomOf="@+id/linearLayout9">

        <ScrollView
            android:layout_width="450dp"
            android:layout_height="0dp"
            android:padding="20dp"
            android:layout_weight="1"
            android:background="@drawable/fondo_cuaderno_tiempo"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout9">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="35dp"
                        android:layout_height="35dp"
                        android:src="@drawable/svg_licences" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Licencias de código abierto"
                        android:layout_gravity="center"
                        android:layout_marginStart="10dp"
                        android:textColor="?colorOnSurface"
                        android:textSize="18sp"
                        android:fontFamily="@font/montserrat_bold"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/montserrat_bold"
                    android:layout_marginBottom="7dp"
                    android:text="Ilustraciones"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="3dp"
                    android:text="Centro Aragonés para la Comunicación Aumentativa y Alternativa"/>

                <TextView
                    android:id="@+id/arasaacLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="?customLinkColor"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="5dp"
                    android:text="Condiciones de uso, Noviembre 2023"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="3dp"
                    android:text="manypixels"/>

                <TextView
                    android:id="@+id/manypixelsLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:layout_marginBottom="5dp"
                    android:textColor="?customLinkColor"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginStart="10dp"
                    android:text="Terms of Service, 25 de Enero, 2019"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="3dp"
                    android:text="Freepik"/>

                <TextView
                    android:id="@+id/freepikLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="?customLinkColor"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="Terms of Use, Marzo, 2023"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/montserrat_bold"
                    android:layout_marginBottom="7dp"
                    android:text="Iconos"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="3dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="SVG Repo"/>

                <TextView
                    android:id="@+id/svgRepoLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="?customLinkColor"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="SVG Repo License, 03 de Enero, 2023"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="?colorOnSurface"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="3dp"
                    android:fontFamily="@font/montserrat_medium"
                    android:text="Flaticon"/>

                <TextView
                    android:id="@+id/flatIconLink"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="?customLinkColor"
                    android:fontFamily="@font/montserrat_medium"
                    android:layout_marginStart="10dp"
                    android:text="Terms of Use, Junio, 2022"/>


            </LinearLayout>

        </ScrollView>

        <LinearLayout
            android:layout_width="450dp"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:background="@drawable/fondo_cuaderno_tiempo"
            android:layout_marginTop="30dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout9"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/svg_terms"/>

                <TextView
                    android:id="@+id/txt_terms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Términos de servicio"
                    android:textColor="?colorOnSurface"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:textSize="18sp"
                    android:fontFamily="@font/montserrat_bold"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:src="@drawable/svg_privacy" />

                <TextView
                    android:id="@+id/txt_privacy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Política de privacidad"
                    android:layout_gravity="center"
                    android:textColor="?colorOnSurface"
                    android:layout_marginStart="10dp"
                    android:textSize="18sp"
                    android:fontFamily="@font/montserrat_bold"/>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>



</androidx.constraintlayout.widget.ConstraintLayout>