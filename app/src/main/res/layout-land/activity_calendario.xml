<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?backgroundColor"
    tools:context=".presentacion.actividades.CalendarioActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob3"
        app:tint="?subColorBackground" />

    <ImageView
        android:id="@+id/imageView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/fragmentContainerViewSide"
        app:srcCompat="@drawable/svg_blob" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintWidth_percent="0.85"
        app:layout_constraintHeight_percent="0.82"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/fragmentContainerViewSide"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/linearLayout"
            android:layout_width="match_parent"
            android:layout_weight="0.45"
            android:layout_height="match_parent"
            android:background="@drawable/bg_calendario"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:contentDescription="Mes y flechas de navegación atras/delante"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/image_calendar_anterior"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Flecha mes anterior"
                    app:srcCompat="@drawable/ic_baseline_arrow_back_32"
                    app:tint="?colorOnSurface" />

                <TextView
                    android:id="@+id/lbl_mes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="2"
                    android:contentDescription="Mes"
                    android:fontFamily="@font/poppins_medium"
                    android:text="Noviembre 2021"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="17sp" />

                <ImageView
                    android:id="@+id/image_calendar_siguiente"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_weight="1"
                    android:contentDescription="Flecha mes siguiente"
                    app:srcCompat="@drawable/ic_baseline_arrow_forward_32"
                    app:tint="?colorOnSurface" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/lbl_lunes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Lunes"
                    android:fontFamily="@font/poppins_medium"
                    android:text="LUN"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/lbl_martes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Martes"
                    android:fontFamily="@font/poppins_medium"
                    android:text="MAR"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/lbl_miercoles"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Miércoles"
                    android:fontFamily="@font/poppins_medium"
                    android:text="MIE"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/lbl_jueves"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Jueves"
                    android:fontFamily="@font/poppins_medium"
                    android:text="JUE"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/lbl_viernes"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:autoSizeTextType="uniform"
                    android:contentDescription="Viernes"
                    android:fontFamily="@font/poppins_medium"
                    android:text="VIE"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/lbl_sabado"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Sábado"
                    android:fontFamily="@font/poppins_medium"
                    android:text="SAB"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/lbl_domingo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:contentDescription="Domingo"
                    android:fontFamily="@font/poppins_medium"
                    android:text="DOM"
                    android:textAlignment="center"
                    android:textColor="?colorOnSurface"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_calendario"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:overScrollMode="never" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/fragment_calendario"
            android:layout_width="match_parent"
            android:layout_weight="0.5"
            android:layout_height="match_parent"
            android:layout_marginStart="30dp"
            android:background="@drawable/bg_calendario" />

    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerViewSide"
        android:name="com.example.plantea.presentacion.fragmentos.NavigationSideFragment"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:elevation="5dp"
        app:shapeAppearance="@style/cornersNavigation"
        android:background="?colorAccent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>


</androidx.constraintlayout.widget.ConstraintLayout>