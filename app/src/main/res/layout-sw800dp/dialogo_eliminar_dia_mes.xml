<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login"
    android:layout_margin="15dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/lbl_Logout2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:paddingStart="70dp"
            android:paddingEnd="70dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="10dp"
            android:text="@string/lbl_eliminarFecha"
            android:textColor="?colorOnSurface"
            android:textSize="22sp" />

        <TextView
            android:id="@+id/lbl_Logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:paddingStart="70dp"
            android:paddingEnd="70dp"
            android:text="@string/lbl_eliminarFechaMensaje"
            android:textColor="?colorOnSurface"
            android:textSize="17sp"
            android:maxLines="2"
            android:autoSizeMinTextSize="20sp"
            app:autoSizeTextType="uniform" />

        <Button
            android:id="@+id/btn_eliminar"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#203130"
            app:cornerRadius="25dp"
            android:textSize="14sp"
            android:textAllCaps="true"
            android:layout_margin="20dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/lbl_eliminar"
            />

    </LinearLayout>


    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_margin="20dp"
        android:contentDescription="Cerrar seccion"
        android:background="@drawable/bg_close_button"
        android:src="@drawable/ic_baseline_close_24"
        android:padding="12dp"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>