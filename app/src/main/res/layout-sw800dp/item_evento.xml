<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:id="@+id/card_Evento"
    android:layout_height="wrap_content"
    app:cardCornerRadius="13dp"
    app:cardElevation="0dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="?backgroundTint">

        <LinearLayout
            android:id="@+id/leftLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="5dp">

            <TextView
                android:id="@+id/txt_evento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/poppins_regular"
                android:text="Cita"
                android:textAlignment="viewStart"
                android:textColor="?colorOnSurface"
                android:textSize="17sp" />

            <TextView
                android:id="@+id/txt_hora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/poppins_regular"
                android:text="Hora"
                android:textColor="?colorOnSurface"
                android:textSize="17sp" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/rightLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/img_eventoVisible"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="10dp"
                app:srcCompat="@drawable/svg_eye_off" />

            <ImageView
                android:id="@+id/img_borrarEvento"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="10dp"
                app:srcCompat="@drawable/svg_trash" />

            <ImageView
                android:id="@+id/img_exportCalendar"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="10dp"
                app:srcCompat="@drawable/svg_export" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>