<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="300dp"
    android:layout_gravity="center"
    android:id="@+id/fragment_nuevo_picto_nombre"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <FrameLayout
            android:id="@+id/card_imagen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_textinputedit"
            app:layout_constraintBottom_toBottomOf="@+id/switch_termometro"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.155"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/txt_Titulo">

            <ImageView
                android:id="@+id/img_NuevoPicto"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_margin="5dp"
                app:shapeAppearance="@style/cornerRadius" />

            <ImageView
                android:id="@+id/id_editIcon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="top|end"
                android:layout_margin="5dp"
                android:visibility="gone"
                android:contentDescription="@string/lbl_Consultas"
                app:srcCompat="@drawable/edit_image_svg" />

        </FrameLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Titulo"
            style="@style/cornertextInput"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:contentDescription="Campo de texto nombre de usuario"
            android:ems="10"
            android:hint="@string/lbl_tulo"
            android:inputType="text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/card_imagen"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                style="@style/textInput"/>
        </com.google.android.material.textfield.TextInputLayout>


        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switch_termometro"
            style="@style/Widget.Material3.CompoundButton.MaterialSwitch"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_textinputedit"
            android:contentDescription="Interruptor, información del planificado"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center_vertical"
            android:padding="15dp"
            android:text="@string/termometro"
            android:textColor="?colorOnSurface"
            android:textSize="17sp"
            app:layout_constraintEnd_toEndOf="@+id/txt_Titulo"
            app:layout_constraintStart_toStartOf="@+id/txt_Titulo"
            app:layout_constraintTop_toBottomOf="@+id/txt_Titulo" />

        <Button
            android:id="@+id/btn_GuardarPicto"
            style="@style/Widget.Material3.Button"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="70dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/crear_cuaderno"
            android:textColor="@color/darkGreen"
            android:textSize="@dimen/button"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/switch_termometro"
            app:layout_constraintVertical_bias="0.0" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>



