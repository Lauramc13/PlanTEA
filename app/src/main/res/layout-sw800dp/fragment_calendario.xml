<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/linearLayout"
    android:layout_width="match_parent"
    android:paddingBottom="20dp"
    android:layout_height="match_parent"
    android:background="@drawable/bg_calendario"
    android:contentDescription="Contenedor de calendario"
    android:orientation="vertical"
    app:layout_constraintStart_toStartOf="parent">

    <ImageView
        android:id="@+id/cerrarFragment"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_gravity="end"
        android:layout_margin="10dp"
        android:background="@drawable/bg_close_button"
        android:contentDescription="Cerrar configuración nuevo evento"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_baseline_close_24" />

    <LinearLayout
        android:id="@+id/linearLayout17"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:contentDescription="Mes y flechas de navegación atras/delante"
        android:orientation="horizontal"
        android:padding="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cerrarFragment">

        <Button
            android:id="@+id/image_calendar_anterior"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginStart="20dp"
            android:layout_weight="0"
            android:contentDescription="Flecha mes siguiente"
            android:gravity="center"
            android:padding="20dp"
            android:scaleType="centerInside"
            app:icon="@drawable/svg_chevron_left"
            app:iconGravity="textStart"
            app:iconSize="35dp" />

        <TextView
            android:id="@+id/lbl_mes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_weight="1"
            android:contentDescription="Mes"
            android:fontFamily="@font/poppins_semibold"
            android:text="Noviembre 2021"
            android:textAlignment="center"
            android:textColor="?colorOnSurface"
            android:textSize="20sp" />

        <Button
            android:id="@+id/image_calendar_siguiente"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginEnd="20dp"
            android:layout_weight="0"
            android:contentDescription="Flecha mes siguiente"
            android:gravity="center"
            android:padding="20dp"
            android:scaleType="centerInside"
            app:icon="@drawable/svg_chevron_right"
            app:iconGravity="textStart"
            app:iconSize="35dp" />

    </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_calendario"
            android:layout_width="460dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:contentDescription="Contenedor con los días del mes"
            android:overScrollMode="never"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginBottom="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/linearLayout17" />
    </androidx.constraintlayout.widget.ConstraintLayout>

