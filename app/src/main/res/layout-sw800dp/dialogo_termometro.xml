<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:id="@+id/card_presentacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="340dp"
            android:layout_height="wrap_content"
            android:background="?colorBG1">

            <ImageView
                android:id="@+id/icono_CerrarDialogoEvento"
                android:layout_width="48dp"
                android:layout_height="40dp"
                android:layout_margin="10dp"
                android:layout_gravity="end"
                android:padding="12dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:background="@drawable/bg_close_button"
                app:srcCompat="@drawable/ic_baseline_close_24" />


            <ImageView
                android:id="@+id/icono_escuchar"
                android:layout_width="48dp"
                android:layout_height="40dp"
                android:layout_margin="10dp"
                android:layout_gravity="start"
                android:padding="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:background="@drawable/bg_close_button"
                app:srcCompat="@drawable/svg_sound" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/img_pictograma"
                android:layout_width="297dp"
                android:layout_height="286dp"
                android:layout_marginTop="65dp"
                app:shapeAppearance="@style/cornerRadius"
                android:background="@color/white"
                style="@style/pictogramas"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0"
                app:srcCompat="@drawable/cuaderno_dolor_oido" />

            <TextView
                android:id="@+id/lbl_pictograma"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="15dp"
                android:foregroundGravity="center"
                android:text="Pictograma"
                android:fontFamily="@font/poppins_medium"
                android:textColor="?colorOnSurface"
                android:textSize="36sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.478"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/img_pictograma"
                app:layout_constraintVertical_bias="0.024" />

            <LinearLayout
                android:id="@+id/termometro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:padding="5dp"
                android:layout_marginBottom="15dp"
                android:contentDescription="Simulación termometro"
                android:background="@drawable/termometro_fondo"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lbl_pictograma">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/imageView"
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:contentDescription="Me encuentro bien"
                        app:srcCompat="@drawable/termometro_bien" />

                    <ImageView
                        android:id="@+id/imageView2"
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginStart="30dp"
                        android:contentDescription="Me encuentro algo mal"
                        app:srcCompat="@drawable/termometro_regular" />

                    <ImageView
                        android:id="@+id/imageView4"
                        android:layout_width="65dp"
                        android:layout_height="65dp"
                        android:layout_marginStart="30dp"
                        android:contentDescription="Me encuentro muy mal"
                        app:srcCompat="@drawable/termometro_mal" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekBar_termometro"
                    android:layout_width="275dp"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="5dp"
                    android:progress="10"
                    android:progressDrawable="@drawable/seekbar_estilo"
                    android:splitTrack="false"
                    android:thumb="@drawable/estilo_thumb" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>