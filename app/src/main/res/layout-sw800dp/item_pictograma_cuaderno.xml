<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="10dp">

    <RelativeLayout
        android:id="@+id/card_pictograma"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="@drawable/card_personalizado"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/id_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="0dp"
            android:orientation="vertical">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/id_Imagen"
                style="@style/pictogramas"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_alignParentEnd="true"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="15dp"
                android:background="@color/white"
                android:contentDescription="@string/lbl_Consultas"
                app:shapeAppearance="@style/cornerRadius"
                app:srcCompat="@drawable/categoria_consultas" />

            <TextView
                android:id="@+id/id_Texto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="8dp"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="5dp"
                android:autoSizeTextType="uniform"
                android:fontFamily="@font/montserrat_regular"
                android:maxLines="1"
                android:text="@string/lbl_Consultas"
                android:textColor="?colorOnSurface"
                android:textSize="15sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_sin_aniadir"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:backgroundTint="@color/darkGray"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            app:icon="@drawable/svg_add"
            app:iconTint="@color/darkdarkGray"
            app:iconSize="25dp"
            android:padding="10dp"
            app:iconGravity="textStart"
            android:drawableEnd="@drawable/card_personalizado_cuaderno"
            android:visibility="invisible" />

        <Button
            android:id="@+id/btn_aniadido"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="5dp"
            android:layout_marginEnd="5dp"
            app:icon="@drawable/svg_check"
            app:iconTint="?colorOnSecondaryContainer"
            app:iconSize="25dp"
            android:padding="10dp"
            app:iconGravity="textStart"
            android:drawableEnd="@drawable/card_personalizado_cuaderno"
            android:visibility="invisible" />

        <ImageView
            android:id="@+id/btn_borrarPicto"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:padding="8dp"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:layout_alignParentStart="true"
            android:elevation="4dp"
            android:visibility="visible"
            app:srcCompat="@drawable/svg_trash">
        </ImageView>
    </RelativeLayout>



</androidx.constraintlayout.widget.ConstraintLayout>