<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?customBgColor"
    tools:context=".presentacion.actividades.ConfiguracionActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerView"
        android:name="com.example.plantea.presentacion.fragmentos.NavigationTopFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/scrollview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fragmentContainerView"
        tools:context=".presentacion.actividades.ConfiguracionActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:contentDescription="Contenedor con la configuración del usuario"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="15dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_cards_configuracion"
                android:contentDescription="Contenedor del planificador"
                android:elevation="0dp">

                <TextView
                    android:id="@+id/lbl_infoPlanificador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_marginTop="20dp"
                    android:contentDescription="Titulo, información del planificador"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/lbl_infoPlanificador"
                    android:textColor="?colorOnSurface"
                    android:textSize="20sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:fontFamily="@font/poppins_medium"
                    android:text="@string/lbl_infoplaificador_texto"
                    android:textColor="?colorOutline"
                    android:textSize="16sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_infoPlanificador" />


                <RelativeLayout
                    android:id="@+id/id_card_Planificador"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginTop="36dp"
                    android:background="@drawable/card_personalizado"
                    android:elevation="0dp"
                    android:layout_marginEnd="20dp"
                    app:layout_constraintEnd_toStartOf="@+id/linearLayout10"
                    app:layout_constraintTop_toBottomOf="@+id/textView2">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/img_FotoPlanificador"
                        style="@style/addPhotoBackground"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="1dp"
                        android:background="@drawable/ic_baseline_add_photo_alternate_128"
                        android:contentDescription="Añadir imagen del planificador"
                        app:shapeAppearance="@style/cornerRadius" />

                    <ImageView
                        android:id="@+id/id_editIcon"
                        android:layout_width="33dp"
                        android:layout_height="33dp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="5dp"
                        android:layout_marginEnd="5dp"
                        android:contentDescription="@string/lbl_Consultas"
                        android:elevation="4dp"
                        app:srcCompat="@drawable/edit_image_svg" />
                </RelativeLayout>

                <LinearLayout
                    android:id="@+id/linearLayout10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="35dp"
                    android:layout_marginBottom="35dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.65"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/textView2">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/txt_nombrePlanificador"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="340dp"
                        android:layout_height="wrap_content"
                        android:contentDescription="Campo de texto con nombre del planificador"
                        android:ems="10"
                        android:fontFamily="@font/poppins_medium"
                        android:hint="@string/lbl_datosNombre"
                        android:inputType="textPersonName"
                        android:maxLength="14"
                        android:layout_marginBottom="5dp"
                        android:textColor="?colorOnSurface"
                        android:textCursorDrawable="@null"
                        app:layout_constraintStart_toEndOf="@+id/id_card_Planificador">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:cursorVisible="true"
                            android:inputType="text"
                            android:textColor="?colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/txt_nombreUsuarioPlanificador"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="340dp"
                        android:layout_height="wrap_content"
                        android:contentDescription="Campo de texto con nombre de usuario del planificador"
                        android:ems="10"
                        android:fontFamily="@font/poppins_medium"
                        android:hint="@string/lbl_nombreUsuario"
                        android:inputType="textPersonName"
                        android:maxLength="14"
                        android:layout_marginBottom="5dp"
                        android:textColor="?colorOnSurface"
                        android:textCursorDrawable="@null"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/id_card_Planificador"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_infoPlanificador"
                        app:layout_constraintVertical_bias="0.214">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:cursorVisible="true"
                            android:inputType="text"
                            android:textColor="?colorOnSurface" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/txt_correoPlanificador"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="340dp"
                        android:layout_height="wrap_content"
                        android:contentDescription="Campo de texto con correo del planificador"
                        android:ems="10"
                        android:fontFamily="@font/poppins_medium"
                        android:hint="@string/lbl_email"
                        android:inputType="textPersonName"
                        android:maxLength="14"
                        android:enabled="false"
                        android:textColor="?colorOnSurface"
                        android:textCursorDrawable="@null"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/id_card_Planificador"
                        app:layout_constraintTop_toBottomOf="@+id/lbl_infoPlanificador"
                        app:layout_constraintVertical_bias="0.214">

                        <com.google.android.material.textfield.TextInputEditText
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:cursorVisible="true"
                            android:inputType="text"
                            android:textColor="?colorOnSurface"
                            android:alpha="0.6"/>
                    </com.google.android.material.textfield.TextInputLayout>


                    <Button
                        android:id="@+id/buttonContrasenia"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="45dp"
                        android:contentDescription="Boton para cambiar contraseña del usuario"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="@string/btn_CambiarPass"
                        android:textColor="#203130"
                        android:textSize="@dimen/button"
                        android:textAllCaps="true"
                        app:cornerRadius="25dp"
                        android:layout_marginTop="20dp" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_viewUsers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginBottom="15dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:elevation="0dp"/>

            <Button
                android:id="@+id/btn_guardarConfiguracion"
                style="@style/Widget.Material3.Button"
                android:layout_width="200dp"
                android:layout_marginTop="10dp"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_semibold"
                android:textColor="#203130"
                app:cornerRadius="25dp"
                android:contentDescription="Boton guardar configuración"
                android:text="@string/btn_Guardar"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btn_credits"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15.5sp"
                android:padding="10dp"
                android:text="@string/pantalla_acercade"
                android:layout_gravity="center_horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

        </LinearLayout>
