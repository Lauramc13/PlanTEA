<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="550dp"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login">

        <TextView
            android:id="@+id/lbl_NuevoPicto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:text="@string/lbl_NuevoPicto"
            android:textColor="?colorOnSurface"
            android:fontFamily="@font/poppins_bold"
            android:textSize="22sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    <FrameLayout
        android:id="@+id/frameImage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/frameLayout_Categorias"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.155"
        android:background="@drawable/bg_textinputedit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/txt_Titulo">


        <ImageView
            android:id="@+id/img_NuevoPicto"
            style="@style/addPhotoBackground"
            android:layout_width="130dp"
            android:layout_height="130dp"
            android:layout_margin="1dp"
            android:background="@drawable/ic_baseline_add_photo_alternate_128"
            app:shapeAppearance="@style/cornerRadius" />
    </FrameLayout>




