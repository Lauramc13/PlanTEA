<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="650dp"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login">

    <TextView
        android:id="@+id/lbl_NuevoPicto"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="25dp"
        android:text="Titulo"
        android:textColor="?colorOnSurface"
        android:fontFamily="@font/poppins_semibold"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/buttons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@+id/lbl_NuevoPicto">

        <TextView
            android:id="@+id/btn_arasaac"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="45dp"
            android:textColor="#000000"
            app:backgroundTint="@null"
            android:enabled="false"
            android:gravity="center"
            android:textSize="@dimen/buttonBig"
            android:fontFamily="@font/poppins_regular"
            android:background="@drawable/bg_button_nuevo_picto"
            android:text="ARASAAC" />

        <TextView
            android:id="@+id/btn_galeria"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="45dp"
            android:textColor="#000000"
            app:backgroundTint="@null"
            android:gravity="center"
            android:focusedByDefault="false"
            android:textSize="@dimen/buttonBig"
            android:fontFamily="@font/poppins_regular"
            android:background="@drawable/bg_button_nuevo_picto"
            android:text="@string/desde_galeria" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/fragment_nuevoPicto"
        android:layout_width="match_parent"
        android:layout_height="350dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:foregroundGravity="center"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@+id/btn_siguiente"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/buttons" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_siguiente"
        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:elevation="0dp"
        android:enabled="false"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="@string/next"
        android:textAllCaps="true"
        android:textSize="@dimen/button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_margin="15dp"
        android:contentDescription="Cerrar seccion"
        android:background="@drawable/bg_close_button"
        android:src="@drawable/ic_baseline_close_24"
        android:padding="12dp"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>