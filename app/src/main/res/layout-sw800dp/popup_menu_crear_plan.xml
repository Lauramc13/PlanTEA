<!-- res/layout/custom_popup_cuaderno.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="@drawable/bg_popup">

    <TextView
        android:id="@+id/item_historia"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/bocadillo_historia_off"
        android:drawableTint="?colorOnSurface"
        android:drawablePadding="8dp"
        android:text="@string/texto_adicional"
        android:gravity="center_vertical"
        android:textSize="14sp"
        android:padding="5dp"
        android:layout_marginEnd="15dp"
        android:fontFamily="@font/poppins_regular"
        android:clickable="true"
        android:textColor="?colorOnSurface" />

    <TextView
        android:id="@+id/item_duracion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/svg_clock_2"
        android:drawablePadding="8dp"
        android:text="@string/duracion"
        android:gravity="center_vertical"
        android:drawableTint="?colorOnSurface"
        android:textSize="14sp"
        android:padding="5dp"
        android:textColor="?colorOnSurface"
        android:layout_marginEnd="30dp"
        android:fontFamily="@font/poppins_regular"
        android:clickable="true" />

    <TextView
        android:id="@+id/item_entretenimiento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:drawableLeft="@drawable/svg_game"
        android:drawablePadding="8dp"
        android:text="@string/actividad_entre"
        android:drawableTint="?colorOnSurface"
        android:textSize="14sp"
        android:padding="5dp"
        android:layout_marginEnd="15dp"
        android:textColor="?colorOnSurface"
        android:fontFamily="@font/poppins_regular"
        android:clickable="true" />

</LinearLayout>
