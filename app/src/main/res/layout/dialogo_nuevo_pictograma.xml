<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:paddingStart="35dp"
        android:paddingEnd="35dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/lbl_NuevoPicto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="@string/lbl_NuevoPicto"
            android:textColor="?colorOnSurface"
            android:fontFamily="@font/poppins_bold"
            android:textSize="@dimen/modalTitle" />

        <FrameLayout
            android:id="@+id/id_card_Planificador"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="36dp"
            android:background="@drawable/borde_imagen_nueva"
            android:alpha="0.5"
            android:layout_gravity="center">

            <ImageView
                android:id="@+id/img_NuevoPicto"
                style="@style/colorNewPhoto"
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:layout_gravity="center"
                android:background="@drawable/ic_baseline_add_photo_alternate_128" />
        </FrameLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Titulo"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:background="@drawable/fondo_texto_login"
            android:contentDescription="Campo de texto nombre de usuario"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_datosNombre"
            android:inputType="text"
            android:textColor="?colorOnSurface"
            app:shapeAppearance="@style/cornerRadiusLogin">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:inputType="text"
                android:textSize="16sp"
                android:textColor="?colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>


        <FrameLayout
            android:id="@+id/frameLayout_Categorias"
            android:layout_width="250dp"
            android:layout_height="52dp"
            android:layout_marginTop="15dp">

            <Spinner
                android:id="@+id/spinner_Categorias"
                style="@style/dropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/border_spinner"
                android:fontFamily="@font/poppins_regular"
                android:popupBackground="@drawable/custom_popup_background"
                android:spinnerMode="dropdown"
                android:textColor="?colorOnSurface" />

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="end|bottom"
                android:layout_marginEnd="10dp"
                android:contentDescription="@null"
                android:src="@drawable/svg_arrow_down" />
        </FrameLayout>

        <Button
            android:id="@+id/btn_GuardarPicto"
            style="@style/Widget.Material3.Button"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="35dp"
            android:text="@string/btn_Guardar"
            android:textSize="14sp"
            android:textColor="#203130"
            android:fontFamily="@font/poppins_semibold" />

    </LinearLayout>


    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_margin="10dp"
        android:contentDescription="Cerrar dialogo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_baseline_close_24" />

</androidx.constraintlayout.widget.ConstraintLayout>