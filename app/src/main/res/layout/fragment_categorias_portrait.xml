<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".presentacion.fragmentos.CategoriasFragment"
    android:id="@+id/categoriasPortrait">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="60dp"
        >

        <androidx.gridlayout.widget.GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:columnCount="2"
            android:paddingTop="20dp"
            android:paddingRight="20dp"
            android:paddingLeft="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:rowCount="4">

            <androidx.cardview.widget.CardView
                android:id="@+id/categoria_consultas"
                android:layout_width="175dp"
                android:paddingLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?color"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/img_Consultas"
                        android:layout_width="match_parent"
                        android:layout_height="87dp"
                        android:contentDescription="@string/lbl_Consultas"
                        app:srcCompat="@drawable/categoria_consultas">

                    </ImageView>

                    <TextView
                        android:id="@+id/lbl_Consultas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="@string/lbl_Consultas"
                        android:textAlignment="center"
                        android:textColor="?colorOnSurface"
                        android:textSize="16sp">

                    </TextView>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/categoria_profesionales"
                android:layout_width="175dp"
                android:paddingRight="20dp"

                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?color"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/img_Profesionales"
                        android:layout_width="match_parent"
                        android:layout_height="87dp"
                        android:contentDescription="@string/lbl_profesionales"
                        app:srcCompat="@drawable/categoria_profesionales">

                    </ImageView>

                    <TextView
                        android:id="@+id/lbl_profesionales"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="@string/lbl_profesionales"
                        android:textAlignment="center"
                        android:textColor="?colorOnSurface"
                        android:textSize="16sp">

                    </TextView>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/categoria_lugares"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="20dp"
                android:paddingRight="20dp"
                android:paddingLeft="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?color"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/img_Lugares"
                        android:layout_width="match_parent"
                        android:layout_height="87dp"
                        android:contentDescription="@string/lbl_Lugares"

                        app:srcCompat="@drawable/categoria_lugares">

                    </ImageView>

                    <TextView
                        android:id="@+id/lbl_Lugares"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="@string/lbl_Lugares"
                        android:textAlignment="center"
                        android:textColor="?colorOnSurface"
                        android:textSize="16sp">

                    </TextView>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/categoria_desplazamiento"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:paddingRight="20dp"
                android:paddingLeft="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?color"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/img_Desplazamiento"
                        android:layout_width="match_parent"
                        android:layout_height="87dp"
                        android:contentDescription="@string/lbl_Desplazamiento"
                        app:srcCompat="@drawable/categoria_desplazamiento">

                    </ImageView>

                    <TextView
                        android:id="@+id/lbl_Desplazamiento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="@string/lbl_Desplazamiento"
                        android:textAlignment="center"
                        android:textColor="?colorOnSurface"
                        android:textSize="16sp">

                    </TextView>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/categoria_accion"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:layout_marginRight="20dp"
                android:paddingRight="20dp"
                android:paddingLeft="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?color"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/img_Accion"
                        android:layout_width="match_parent"
                        android:layout_height="87dp"
                        android:contentDescription="@string/lbl_Accion"
                        app:srcCompat="@drawable/categoria_accion">

                    </ImageView>

                    <TextView
                        android:id="@+id/lbl_Accion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="@string/lbl_Accion"
                        android:textAlignment="center"
                        android:textColor="?colorOnSurface"
                        android:textSize="16sp">

                    </TextView>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/categoria_entretenimiento"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:paddingRight="20dp"
                android:paddingLeft="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FEFFBE"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/img_Entretenimiento"
                        android:layout_width="match_parent"
                        android:layout_height="87dp"
                        android:contentDescription="@string/lbl_Entretenimiento"
                        app:srcCompat="@drawable/categoria_entretenimiento">

                    </ImageView>

                    <TextView
                        android:id="@+id/lbl_Entretenimiento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="@string/lbl_Entretenimiento"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="16sp">

                    </TextView>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/categoria_recompensa"
                android:layout_width="175dp"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:layout_marginRight="20dp"
                android:paddingRight="20dp"
                android:paddingLeft="20dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FEFFBE"
                    android:orientation="vertical">

                    <ImageView
                        android:id="@+id/img_Recompensa"
                        android:layout_width="match_parent"
                        android:layout_height="87dp"
                        android:contentDescription="@string/lbl_Recompensa"
                        app:srcCompat="@drawable/categoria_recompensa">

                    </ImageView>

                    <TextView
                        android:id="@+id/lbl_Recompensa"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="@string/lbl_Recompensa"
                        android:textAlignment="center"
                        android:textColor="@color/black"
                        android:textSize="16sp">

                    </TextView>
                </LinearLayout>

            </androidx.cardview.widget.CardView>


        </androidx.gridlayout.widget.GridLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>





