<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:id="@+id/linearLayout8"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="350dp"
        app:layout_constraintWidth_percent="0.8">

        <TextView
            android:id="@+id/textView7"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginBottom="20dp"
            android:autoSizeTextType="uniform"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:text="@string/bienvenido_de_nuevo"
            android:textColor="?colorOnSurface"
            app:autoSizeTextType="uniform" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Email"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/fondo_texto_login"
            android:contentDescription="Campo de texto nombre de usuario"
            android:ems="10"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_email"
            android:inputType="text"
            android:textColor="?colorOnSurface"
            app:shapeAppearance="@style/cornerRadiusLogin">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="text"
                android:textColor="?colorOnSurface"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Password"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/fondo_texto_login"
            android:contentDescription="Campo de texto contraseña"
            android:ems="10"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_contrasena"
            android:inputType="textPassword"
            android:textColor="?colorOnSurface"
            app:endIconMode="password_toggle"
            app:layout_constraintStart_toStartOf="@+id/txt_UserName"
            app:layout_constraintTop_toBottomOf="@+id/txt_UserName"
            app:shapeAppearance="@style/cornerRadiusLogin">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="textPassword"
                android:textColor="?colorOnSurface"
                android:textSize="16sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_login"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:contentDescription="Boton iniciar sesion"
            android:elevation="0dp"
            android:fontFamily="@font/poppins_semibold"
            android:maxWidth="10dp"
            android:text="@string/lbl_iniciarSesion"
            android:textColor="#203130"
            android:textSize="@dimen/button"
            app:cornerRadius="10dp"
            app:layout_constraintBottom_toTopOf="@+id/btn_registrar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_Password" />

        <!--<TextView
            android:id="@+id/btn_olvidar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:textSize="@dimen/body"
            android:text="@string/lbl_contraseniaOlvidada"
            android:textColor="?colorOnSurface" />-->

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:src="@drawable/svg_separador" />

        <Button
            android:id="@+id/Signin"
            style="@style/Widget.Material3.Button.IconButton.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="?configuracionCardBg"
            android:contentDescription="Boton iniciar sesion"
            android:fontFamily="@font/poppins_semibold"
            android:text="INICIAR SESIÓN CON GOOGLE"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/button"
            app:cornerRadius="10dp"
            android:layout_marginBottom="60dp"
            app:icon="@drawable/svg_google_icon"
            app:iconSize="28dp"
            app:iconTint="@null"
            app:strokeWidth="1dp" />

      <!--  <TextView
            android:id="@+id/btn_registrar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp"
            android:contentDescription="Boton registrarse"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:paddingEnd="5dp"
            android:text="@string/lbl_noCuenta"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/body"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />-->

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>