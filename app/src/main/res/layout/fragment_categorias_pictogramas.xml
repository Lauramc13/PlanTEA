<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/frameLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/fragment_personalizado2"
    android:padding="5dp"
    tools:context=".presentacion.fragmentos.CategoriasPictogramasFragment">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_Pictogramas"
        android:layout_width="match_parent"
        android:paddingEnd="5dp"
        android:layout_height="match_parent"
        android:scrollbars="vertical"
        android:layout_marginTop="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/image_CerrarContenedor"/>


    <ImageView
        android:id="@+id/image_CerrarContenedor"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_margin="5dp"
        android:contentDescription="Cerrar seccion"
        android:background="@drawable/bg_close_button"
        android:src="@drawable/svg_close"
        android:padding="12dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/image_add"
        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
        android:elevation="0dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="6dp"
        app:icon="@drawable/svg_add"
        app:iconSize="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/textoNoPictogramas"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_regular"
        android:gravity="center"
        android:text="@string/no_pictogramas_categoria"
        android:textSize="@dimen/body"
        android:visibility="invisible"
        app:layout_constraintBottom_toTopOf="@+id/image_add"
        app:layout_constraintEnd_toEndOf="@+id/recycler_Pictogramas"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/recycler_Pictogramas" />


</androidx.constraintlayout.widget.ConstraintLayout>