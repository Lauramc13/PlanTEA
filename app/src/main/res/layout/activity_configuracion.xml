<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?backgroundSplit"
    tools:context=".presentacion.actividades.ConfiguracionActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_weight="0.7"
            android:contentDescription="Contenedor con la configuración del usuario"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="Contenedor del planificador"
                android:background="@drawable/bg_generalcards"
                android:elevation="4dp">

                <TextView
                    android:id="@+id/lbl_infoPlanificador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="16dp"
                    android:contentDescription="Titulo, información del planificador"
                    android:fontFamily="@font/montserrat_regular"
                    android:text="@string/lbl_infoPlanificador"
                    android:textColor="?colorOnSurface"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_FotoPlanificador"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="5dp"
                    app:shapeAppearance="@style/cornerRadius"
                    android:contentDescription="Añadir imagen del planificador"
                    android:background="@drawable/ic_baseline_add_photo_alternate_128"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/txt_nombrePlanificador"
                    app:layout_constraintHorizontal_bias="0.135"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_infoPlanificador"
                    app:layout_constraintVertical_bias="0.0" />

                <EditText
                    android:id="@+id/txt_nombrePlanificador"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="48dp"
                    android:ems="10"
                    android:fontFamily="@font/montserrat_medium"
                    android:hint="Nombre"
                    android:contentDescription="Campo de texto con nombre del planificador"
                    style="@style/cursorBubble"
                    android:textCursorDrawable="@null"
                    android:textColor="?colorOnSurface"
                    android:maxLength="14"
                    android:textSize="22sp"
                    android:inputType="textPersonName"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/img_FotoPlanificador"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_infoPlanificador"
                    app:layout_constraintVertical_bias="0.214" />

                <Button
                    android:id="@+id/buttonContrasenia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/item_password"
                    android:fontFamily="@font/montserrat_semibold"
                    android:textColor="#203130"
                    android:textSize="12sp"
                    app:cornerRadius="25dp"
                    android:contentDescription="Boton para cambiar contraseña del usuario"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="Contenedor del planificado"
                android:background="@drawable/bg_generalcards"
                android:elevation="4dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_FotoUsuarioTEA"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="5dp"
                    app:shapeAppearance="@style/cornerRadius"
                    android:contentDescription="Añadir imagen del planificado"
                    android:background="@drawable/ic_baseline_add_photo_alternate_128"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/txt_nombreUsuarioTEA"
                    app:layout_constraintHorizontal_bias="0.135"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_infoUsuarioTEA"
                    app:layout_constraintVertical_bias="0.0" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/lbl_infoUsuarioTEA"
                    app:theme="@style/Switches"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/montserrat_regular"
                    android:contentDescription="Interruptor, información del planificado"
                    android:text="@string/lbl_infoUsuarioTEA"
                    android:textColor="?colorOnSurface"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <EditText
                    android:id="@+id/txt_nombreUsuarioTEA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="48dp"
                    android:ems="10"
                    android:fontFamily="@font/montserrat_medium"
                    android:hint="Nombre"
                    style="@style/cursorBubble"
                    android:textCursorDrawable="@null"
                    android:textColor="?colorOnSurface"
                    android:maxLength="14"
                    android:textSize="22sp"
                    android:contentDescription="Campo de texto con nombre del planificado"
                    android:inputType="textPersonName"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/img_FotoUsuarioTEA"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_infoUsuarioTEA"
                    app:layout_constraintVertical_bias="0.214" />

            </androidx.constraintlayout.widget.ConstraintLayout>


            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="Contenedor de la actividad tranquilizadora"
                android:background="@drawable/bg_generalcards"
                android:elevation="4dp">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/lbl_objeto"
                    app:theme="@style/Switches"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="16dp"
                    android:fontFamily="@font/montserrat_regular"
                    android:contentDescription="Interruptor, información de la actividad tranquilizadora"
                    android:text="@string/lbl_configuracion_objeto"
                    android:textColor="?colorOnSurface"
                    android:textSize="24sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/img_objeto"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="5dp"
                    app:shapeAppearance="@style/cornerRadius"
                    android:contentDescription="Añadir imagen de la actividad tranquilizadora"
                    android:background="@drawable/ic_baseline_add_photo_alternate_128"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/txt_nombreObjeto"
                    app:layout_constraintHorizontal_bias="0.135"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_objeto"
                    app:layout_constraintVertical_bias="0.0" />


                <EditText
                    android:id="@+id/txt_nombreObjeto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="48dp"
                    android:ems="10"
                    android:fontFamily="@font/montserrat_medium"
                    android:hint="Nombre objeto"
                    android:contentDescription="Campo de texto con nombre de la actividad tranquilizadora"
                    style="@style/cursorBubble"
                    android:textCursorDrawable="@null"
                    android:textColor="?colorOnSurface"
                    android:inputType="textPersonName"
                    android:textSize="22sp"
                    android:maxLength="10"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/img_objeto"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_objeto"
                    app:layout_constraintVertical_bias="0.214" />
            </androidx.constraintlayout.widget.ConstraintLayout>


        </LinearLayout>
        <View
            android:id="@+id/view1"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@android:color/darker_gray"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="255dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            android:contentDescription="Contenedor de la configuración de las notificaciones"
            android:background="@drawable/bg_generalcards"
            android:elevation="4dp"
            android:orientation="vertical">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_notificacion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                app:theme="@style/Switches"
                android:textColor="?colorOnSurface"
                android:fontFamily="@font/montserrat_regular"
                android:text="@string/lbl_configuracion_notificaciones"
                android:contentDescription="Notificaciones de las citas médicas"
                android:textSize="24sp" />

            <CheckBox
                android:id="@+id/checkBox_hora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                app:buttonTint="?colorPrimary"
                android:textColor="?colorOnSurface"
                android:contentDescription="Casilla de 1 hora antes"
                android:enabled="false"
                android:fontFamily="@font/montserrat_medium"
                android:text="@string/lbl_configuracion_notificaciones_1" />

            <CheckBox
                android:id="@+id/checkBox_dia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                app:buttonTint="?colorPrimary"
                android:textColor="?colorOnSurface"
                android:enabled="false"
                android:fontFamily="@font/montserrat_medium"
                android:contentDescription="Casilla de 1 día antes"
                android:text="@string/lbl_configuracion_notificaciones_2" />

            <CheckBox
                android:id="@+id/checkBox_semana"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                app:buttonTint="?colorPrimary"
                android:textColor="?colorOnSurface"
                android:checked="false"
                android:enabled="false"
                android:fontFamily="@font/montserrat_medium"
                android:contentDescription="Casilla de 1 sesmana antes"
                android:text="@string/lbl_configuracion_notificaciones_3" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:layout_marginStart="10dp">

        <Button
            android:id="@+id/btn_guardarConfiguracion"
            android:layout_width="186dp"
            android:layout_height="68dp"
            android:fontFamily="@font/montserrat_semibold"
            android:maxWidth="10dp"
            android:layout_marginEnd="10dp"
            android:text="@string/btn_Guardar"
            android:contentDescription="Boton guardar configuración"
            android:textColor="#203130"
            app:cornerRadius="25dp"
            />

    </LinearLayout>

</LinearLayout>