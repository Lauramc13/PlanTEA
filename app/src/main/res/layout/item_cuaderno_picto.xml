<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="10dp">

    <RelativeLayout
        android:id="@+id/card_categoria"
        android:layout_width="250dp"
        android:layout_height="200dp"
        android:theme="@style/cards"
        app:cardBackgroundColor="?android:solidColor"
        app:cardCornerRadius="30dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:background="@drawable/card_personalizado_cuaderno"
        app:strokeWidth="2dp">

        <ImageView
            android:id="@+id/id_Imagen"
            android:layout_width="170dp"
            android:layout_height="130dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_gravity="center"
            android:layout_marginStart="40dp"
            android:layout_marginTop="15dp"
            android:layout_marginEnd="40dp"
            android:src="@drawable/card_sentimientos" />

        <TextView
            android:id="@+id/id_Texto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/id_Imagen"
            android:layout_marginStart="10dp"
            android:layout_marginTop="15dp"
            android:layout_marginEnd="10dp"
            android:fontFamily="@font/montserrat_medium"
            android:gravity="center"
            android:text="TITULO"
            android:textColor="?colorOnSurface"
            android:textSize="18sp" />

        <ImageView
            android:id="@+id/btn_borrarCategoria"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:layout_alignParentStart="true"
            android:layout_alignParentTop="true"
            android:layout_marginStart="7dp"
            android:layout_marginTop="3dp"
            android:padding="6dp"
            android:visibility="visible"
            app:srcCompat="@drawable/svg_trash" />

    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>