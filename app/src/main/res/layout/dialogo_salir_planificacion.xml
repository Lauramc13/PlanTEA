<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/widthDialog"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="@dimen/paddingTopDialog"
        android:paddingBottom="15dp"
        app:layout_constraintTop_toBottomOf="@+id/icono_CerrarDialogo">

        <TextView
            android:id="@+id/lbl_Logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:maxLines="2"
            android:paddingStart="70dp"
            android:paddingEnd="70dp"
            android:text="@string/lbl_salirPlanificacion2"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/modalTitle"
            app:autoSizeTextType="uniform" />

        <TextView
            android:id="@+id/lbl_Logout3"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:text="@string/lbl_salirPlanificacion3"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/body" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="10dp"
            android:gravity="center"
            android:padding="10dp">

            <Button
                android:id="@+id/btn_cancelarSalir"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/lbl_cancelar"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/button" />

            <Button
                android:id="@+id/btn_salir"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/lbl_salirPlanificacionBotton"
                android:textAllCaps="false"
                android:textColor="@color/darkGreen"
                android:textSize="@dimen/button" />
        </LinearLayout>

    </LinearLayout>

    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"
        android:contentDescription="Cerrar seccion"
        android:background="@drawable/bg_close_button"
        android:src="@drawable/svg_close"
        android:padding="12dp"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>