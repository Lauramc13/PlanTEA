<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/yesterday"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="@string/ayer"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:gravity="center"
            android:textColor="?colorOnSurface"
            android:fontFamily="@font/poppins_medium"
            android:background="@drawable/start_border_week"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/today"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/hoy"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:textColor="#181F25"
            android:paddingBottom="5dp"
            android:background="@drawable/middle_border_week"
            android:fontFamily="@font/poppins_medium"
            android:textSize="15sp"
            />

        <TextView
            android:id="@+id/tomorrow"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:textColor="?colorOnSurface"
            android:fontFamily="@font/poppins_medium"
            android:background="@drawable/end_border_week"
            android:text="@string/ma_ana"
            android:textSize="15sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/yesterdayArrow"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginTop="-5dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:src="@drawable/svg_arrow_weekly_calendar"
            app:tint="?colorPrimaryContainer" />

        <ImageView
            android:id="@+id/todayArrow"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginTop="-5dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:src="@drawable/svg_arrow_weekly_calendar"
            app:tint="?colorPrimary"/>

        <ImageView
            android:id="@+id/tomorrowArrow"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_marginTop="-5dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:src="@drawable/svg_arrow_weekly_calendar"
            app:tint="?colorPrimaryContainer"/>

    </LinearLayout>

</LinearLayout>