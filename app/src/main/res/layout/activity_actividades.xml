<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?backgroundColor"
    tools:context=".presentacion.actividades.ninio.ActividadActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob3" />

    <ImageView
        android:id="@+id/imageView6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/svg_blob"
        android:layout_marginStart="80dp"
        tools:layout_editor_absoluteX="1dp"
        tools:layout_editor_absoluteY="356dp" />


    <LinearLayout
        android:id="@+id/img_video"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:visibility="visible"
        android:layout_marginStart="80dp"
        android:contentDescription="Contenedor con actividades"
        app:cardBackgroundColor="#B5DFDE"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_objeto"
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="?cardBackgroundColor"
            android:layout_marginBottom="30dp"
            android:contentDescription="Tarjeta de actividad tranquilizadora"
            android:elevation="1dp"
            app:cardCornerRadius="20dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="294dp"
                    android:layout_marginTop="30dp"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/svg_happy" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:layout_marginTop="30dp"
                    android:text="@string/lbl_actividades_objeto"
                    android:textSize="20sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_video"
            android:layout_width="400dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="0dp"
            android:elevation="1dp"
            app:cardCornerRadius="20dp"
            android:contentDescription="Tarjeta de youtube"
            app:cardBackgroundColor="?cardBackgroundColor"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="294dp"
                    android:layout_marginTop="30dp"
                    android:scaleType="centerCrop"
                    app:srcCompat="@drawable/svg_video" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="30dp"
                    android:text="@string/lbl_actividades_youtube"
                    android:textSize="20sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>




    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="90dp"
        android:layout_marginTop="5dp"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Button
            android:id="@+id/goBackButton"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cornerRadius="25dp"
            app:icon="@drawable/svg_go_back"
            app:iconSize="35dp"
            app:iconTint="?colorOnSurface"
            app:backgroundTint="@color/transparent" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actividades"
            android:textSize="22sp"
            android:fontFamily="@font/montserrat_semibold" />

    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="80dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:height="100dp"
        app:itemIconPadding="10dp"
        app:elevation="3dp"
        app:shapeAppearance="@style/cornersNavigation"
        android:background="?colorAccent"
        android:backgroundTint="?colorAccent"
        android:fontFamily="@font/montserrat_light"
        app:headerLayout="@layout/header_drawer_none"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:itemTextAppearance="@null"
        style="@style/Widget.Material3.NavigationView"
        android:layout_marginEnd="1200dp">

        <LinearLayout
            android:id="@+id/accountButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="16dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/roundedImageView"
                android:layout_width="45dp"
                android:layout_height="45dp"
                app:cardCornerRadius="40dp"
                android:layout_margin="5dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/iconoRol"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/white"
                    android:scaleType="centerCrop"
                    android:src="@drawable/user" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/textRol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginStart="10dp"
                android:fontFamily="@font/roboto_medium"
                android:textColor="?colorOnSurfaceVariant"
                android:text="asf" />
        </LinearLayout>

    </com.google.android.material.navigation.NavigationView>

    <ImageView
        android:id="@+id/item_menu"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:padding="8dp"
        android:elevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="15dp"
        android:src="@drawable/svg_menu"
        android:layout_marginStart="15dp"/>

    <FrameLayout
        android:id="@+id/webViewFrame"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginStart="140dp"
        android:layout_marginEnd="60dp"
        android:layout_marginTop="100dp"
        android:layout_marginBottom="50dp"
        android:paddingLeft="1dip"
        android:paddingRight="1dip"
        android:visibility="invisible"
        android:background="@drawable/bg_calendario">

        <Button
            android:id="@+id/closeYoutube"
            style="@style/Widget.Material3.Button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cornerRadius="25dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="10dp"
            android:text="Cerrar reproductor"
            android:textSize="16sp"
            android:textColor="#181F25"
            android:fontFamily="@font/montserrat_semibold"
            app:iconGravity="textEnd"
            app:icon="@drawable/svg_close"
            app:iconSize="25dp"
            app:iconTint="#181F25"
            />

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="10dp"/>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>