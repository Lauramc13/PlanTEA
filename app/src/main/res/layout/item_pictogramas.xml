<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="10dp"
    android:orientation="vertical"
    android:paddingTop="6dp">

    <RelativeLayout
        android:layout_width="200dp"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/id_card"
            android:layout_width="210dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:layout_marginEnd="10dp"
            android:layout_marginBottom="10dp"
            android:background="@drawable/card_personalizado"
            android:elevation="0dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/id_Imagen"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="15dp"
                android:layout_marginLeft="40dp"
                app:shapeAppearance="@style/cornerRadius"
                android:background="@color/white"
                style="@style/pictogramas"
                android:contentDescription="@string/lbl_Consultas"
                app:srcCompat="@drawable/categoria_consultas">
            </com.google.android.material.imageview.ShapeableImageView>

            <TextView
                android:id="@+id/id_Texto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:autoSizeTextType="uniform"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="120dp"
                android:layout_marginBottom="5dp"
                android:foregroundGravity="bottom|center_vertical"
                android:fontFamily="@font/montserrat_regular"
                android:maxLines="1"
                android:gravity="center"
                android:text="@string/lbl_Consultas"
                android:textColor="?colorOnSurface"
                android:textSize="16sp">
            </TextView>

            <ImageView
                android:id="@+id/btn_borrarPicto"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginTop="7dp"
                android:layout_marginRight="5dp"
                android:layout_alignParentRight="true"
                android:elevation="4dp"
                android:visibility="invisible"
                app:srcCompat="@drawable/svg_trash">
            </ImageView>

            <ImageView
                android:id="@+id/btn_favoritosOff"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginTop="7dp"
                android:layout_marginRight="5dp"
                android:layout_alignParentRight="true"
                android:elevation="4dp"
                android:background="@drawable/svg_heart"
                android:visibility="invisible"
                app:srcCompat="@drawable/svg_heart">
            </ImageView>

            <ImageView
                android:id="@+id/btn_favoritosOn"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginTop="7dp"
                android:layout_marginRight="5dp"
                android:layout_alignParentRight="true"
                android:elevation="4dp"
                android:visibility="invisible"
                app:srcCompat="@drawable/svg_heart_filled">
            </ImageView>

            <ImageView
                android:id="@+id/btn_historiaPicto"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_alignParentRight="true"
                android:layout_marginTop="7dp"
                android:layout_marginRight="144dp"
                android:elevation="4dp"
                android:visibility="invisible"
                app:srcCompat="@drawable/bocadillo_historia_off"></ImageView>

            <ImageView
                android:id="@+id/btn_historiaPictoOn"
                android:layout_width="40dp"
                android:layout_height="37dp"
                android:layout_alignParentRight="true"
                android:layout_marginTop="7dp"
                android:layout_marginRight="140dp"
                android:elevation="4dp"
                android:visibility="invisible"
                app:srcCompat="@drawable/bocadillo_historia_on"></ImageView>

        </RelativeLayout>

        <ImageView
            android:id="@+id/id_recompensa"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_alignParentRight="true"
            android:layout_marginTop="-3dp"
            android:layout_marginRight="-18dp"
            android:contentDescription="@string/lbl_Consultas"
            android:elevation="4dp"
            android:visibility="invisible"
            app:srcCompat="@drawable/categoria_recompensa">
        </ImageView>


    </RelativeLayout>
</LinearLayout>