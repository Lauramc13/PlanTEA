<!-- res/layout/activity_main.xml -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="invisible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:indicatorSize="120dp"
            app:trackCornerRadius="5dp"
            android:layout_marginStart="12dp"
            style="@style/Widget.Material3.CircularProgressIndicator"
            app:trackColor="@color/greenLight"
            android:background="@drawable/bg_countdown"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <TextView
            android:id="@+id/timerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="@+id/progressBar"
            app:layout_constraintStart_toStartOf="@+id/progressBar"
            app:layout_constraintEnd_toEndOf="@+id/progressBar"
            android:textColor="?colorOnSurface"
            android:text="00:00:00"
            android:textSize="20sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startButton"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:contentDescription="Botón reproducir lista"
            android:elevation="0dp"
            android:enabled="true"
            android:textColor="#203130"
            android:textSize="20sp"
            app:cornerRadius="25dp"
            app:icon="@drawable/svg_play"
            app:iconGravity="textEnd"
            app:iconSize="25dp"
            app:iconTint="#203130"
            android:layout_marginStart="-40dp"
            app:layout_constraintStart_toEndOf="@+id/progressBar"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/closeButton"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center"
            android:elevation="0dp"
            android:enabled="true"
            android:textColor="#203130"
            android:textSize="20sp"
            app:cornerRadius="25dp"
            app:icon="@drawable/svg_close"
            app:iconGravity="textEnd"
            app:iconSize="25dp"
            app:iconTint="#203130"
            android:layout_marginEnd="-40dp"
            app:layout_constraintEnd_toStartOf="@+id/progressBar"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <Button
        android:id="@+id/showTemporizador"
        style="@style/Widget.Material3.Button.IconButton.Filled"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:text="Temporizador"
        android:textAllCaps="true"
        android:textColor="#203130"
        android:textSize="@dimen/buttonBig"
        app:cornerRadius="25dp"
        app:icon="@drawable/svg_timer"
        app:iconSize="25dp"
        app:iconTint="#203130"
        android:layout_marginTop="25dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
