<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:id="@+id/card_plan"
        android:layout_height="50dp"
        style="@style/items"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="?colorPrimary"
        app:strokeWidth="1dp">

<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_gravity="center">

    <TextView
        android:id="@+id/lbl_Planificacion"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:textSize="15sp"
        android:padding="10dp"
        android:gravity="center"
        android:layout_marginLeft="10dp"
        android:fontFamily="@font/poppins_semibold"
        android:text="Ejemplo plan"/>

    <ImageView
        android:id="@+id/icon_copy"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="70dp"
        android:contentDescription="Copiar planificacion"
        android:padding="13dp"
        app:srcCompat="@drawable/svg_files" />

    <ImageView
        android:id="@+id/icon_edit"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="10dp"
        android:layout_marginEnd="35dp"
        android:contentDescription="Editar planificacion"
        android:layout_alignParentEnd="true"
        app:srcCompat="@drawable/svg_edit"
        />

    <ImageView
        android:id="@+id/icon_delete"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="13dp"
        android:layout_marginEnd="5dp"
        android:contentDescription="Eliminar planificacion"
        android:layout_alignParentEnd="true"
        app:srcCompat="@drawable/svg_trash"
        />

</RelativeLayout>
</com.google.android.material.card.MaterialCardView>
</RelativeLayout>