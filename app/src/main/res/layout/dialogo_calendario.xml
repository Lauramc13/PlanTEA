<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="630dp"
        android:layout_height="550dp"
        android:padding="10dp"
        android:layout_marginLeft="10dp"
        android:background="@drawable/bg_calendario"
        android:orientation="vertical"
        android:contentDescription="Contenedor de calendario"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0">

        <ImageView
            android:id="@+id/icono_CerrarDialogoEvento"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:paddingLeft="10dp"
            android:paddingRight="10dp"
            android:contentDescription="Cerrar dialogo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.051"
            app:srcCompat="@drawable/ic_baseline_close_24" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:contentDescription="Mes y flechas de navegación atras/delante"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/image_calendar_anterior2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:contentDescription="Flecha mes anterior"
                app:srcCompat="@drawable/ic_baseline_arrow_back_32"
                />

            <TextView
                android:id="@+id/lbl_mes2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Noviembre 2021"
                android:layout_gravity="center"
                android:contentDescription="Mes"
                android:fontFamily="@font/montserrat_medium"
                android:textColor="?colorOnSurface"
                android:textAlignment="center"
                android:textSize="20sp" />

            <ImageView
                android:id="@+id/image_calendar_siguiente2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:contentDescription="Flecha mes siguiente"
                app:srcCompat="@drawable/ic_baseline_arrow_forward_32"
                />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:contentDescription="Columna con los dias de la semana"
            android:layout_marginTop="17dp">

            <TextView
                android:id="@+id/lbl_lunes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="L"
                android:contentDescription="Lunes"
                android:textColor="?colorOnSurface"
                android:textAlignment="center"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/lbl_martes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="M"
                android:contentDescription="Martes"
                android:textColor="?colorOnSurface"
                android:fontFamily="@font/montserrat_medium"
                android:textAlignment="center"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/lbl_miercoles"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="X"
                android:contentDescription="Miércoles"
                android:textColor="?colorOnSurface"
                android:fontFamily="@font/montserrat_medium"
                android:textAlignment="center"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/lbl_jueves"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="J"
                android:contentDescription="Jueves"
                android:textColor="?colorOnSurface"
                android:fontFamily="@font/montserrat_medium"
                android:textAlignment="center"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/lbl_viernes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="V"
                android:contentDescription="Viernes"
                android:textColor="?colorOnSurface"
                android:fontFamily="@font/montserrat_medium"
                android:textAlignment="center"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/lbl_sabado"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="S"
                android:contentDescription="Sábado"
                android:textColor="?colorOnSurface"
                android:fontFamily="@font/montserrat_medium"
                android:textAlignment="center"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/lbl_domingo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="D"
                android:contentDescription="Domingo"
                android:textColor="?colorOnSurface"
                android:fontFamily="@font/montserrat_medium"
                android:textAlignment="center"
                android:textSize="15sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_calendario"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:contentDescription="Contenedor con los días del mes"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>