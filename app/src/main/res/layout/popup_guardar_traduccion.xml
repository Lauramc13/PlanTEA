<!-- res/layout/custom_popup_cuaderno.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingStart="15dp"
    android:paddingEnd="15dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="@drawable/bg_popup_2">

    <TextView
        android:id="@+id/item_planificacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/svg_plan_icon_24"
        android:drawableTint="?colorPrimary"
        android:drawablePadding="8dp"
        android:text="@string/planificaci_n"
        android:height="44dp"
        android:textSize="16sp"
        android:gravity="center"
        android:padding="10dp"
        android:fontFamily="@font/poppins_medium"
        android:clickable="true"
        android:textColor="?colorOnSurface"
        android:onClick="onEliminarClicked" />

    <!-- Divider-->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_gravity="center"
        android:background="#B0E8E8" />

    <TextView
        android:id="@+id/item_pdf"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawableLeft="@drawable/svg_pdf"
        android:drawablePadding="8dp"
        android:text="PDF"
        android:drawableTint="?colorPrimary"
        android:textSize="16sp"
        android:height="44dp"
        android:padding="10dp"
        android:textColor="?colorOnSurface"
        android:gravity="center"
        android:layout_marginEnd="30dp"
        android:fontFamily="@font/poppins_medium"
        android:clickable="true"
        android:onClick="onEliminarClicked"/>
</LinearLayout>
