<!-- res/layout/custom_popup_cuaderno.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="15dp"
    android:paddingEnd="15dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="@drawable/bg_popup">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/item_eventos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="5dp"
        android:clickable="true"
        app:strokeWidth="0dp"
        android:backgroundTint="?colorBG1"
        android:focusable="true"
        android:gravity="center">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="25dp"
            android:layout_marginStart="5dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/svg_eventos"
            app:tint="?colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="6dp"
            android:text="@string/pantalla_eventos"
            android:textSize="13sp"
            android:padding="10dp"
            android:layout_marginStart="30dp"
            android:textColor="?colorOnSurfaceVariant"
            android:gravity="center"
            android:fontFamily="@font/roboto_medium"
            />
    </com.google.android.material.card.MaterialCardView>


    <View
        android:id="@+id/divider2"
        android:layout_width="140dp"
        android:layout_height="1dp"
        android:padding="5dp"
        android:layout_gravity="center"
        android:background="?color" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/item_planificaciones"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="5dp"
        android:clickable="true"
        android:backgroundTint="?colorBG1"
        app:strokeWidth="0dp"
        android:focusable="true"
        android:gravity="center">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="25dp"
            android:layout_marginStart="5dp"
            android:layout_gravity="center_vertical"
            android:src="@drawable/svg_plan2"
            app:tint="?colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="6dp"
            android:text="@string/pantalla_planificaciones"
            android:textSize="13sp"
            android:padding="10dp"
            android:layout_marginStart="30dp"
            android:textColor="?colorOnSurfaceVariant"
            android:gravity="center"
            android:fontFamily="@font/roboto_medium"
            />
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
