<!-- res/layout/custom_popup_cuaderno.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="15dp"
    android:paddingEnd="15dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:background="@drawable/bg_popup">

    <LinearLayout
        android:id="@+id/item_idioma"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="5dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center">

        <ImageView
            android:id="@+id/languageImage"
            android:layout_width="26dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="2dp"
            android:layout_marginStart="2dp"
            android:src="@drawable/ic_es" />

        <TextView
            android:id="@+id/languageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="6dp"
            android:text="Español"
            android:textSize="13sp"
            android:padding="5dp"
            android:textColor="?colorOnSurfaceVariant"
            android:gravity="center"
            android:fontFamily="@font/roboto_medium"
            />
    </LinearLayout>

    <View
        android:layout_width="140dp"
        android:layout_height="1dp"
        android:padding="5dp"
        android:layout_gravity="center"
        android:background="?color" />

    <LinearLayout
        android:id="@+id/item_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="5dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="25dp"
            android:src="@drawable/svg_gear"
            app:tint="?colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="6dp"
            android:text="@string/lbl_configuracion"
            android:textSize="13sp"
            android:padding="5dp"
            android:textColor="?colorOnSurfaceVariant"
            android:gravity="center"
            android:fontFamily="@font/roboto_medium"
            />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="140dp"
        android:layout_height="1dp"
        android:padding="5dp"
        android:layout_gravity="center"
        android:background="?color" />

    <LinearLayout
        android:id="@+id/item_cuenta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="5dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="25dp"
            android:src="@drawable/svg_switch"
            app:tint="?colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="6dp"
            android:text="@string/cambiar_rol"
            android:textSize="13sp"
            android:padding="5dp"
            android:textColor="?colorOnSurfaceVariant"
            android:gravity="center"
            android:fontFamily="@font/roboto_medium" />
    </LinearLayout>

    <View
        android:layout_width="140dp"
        android:layout_height="1dp"
        android:padding="5dp"
        android:layout_gravity="center"
        android:background="?color" />

    <LinearLayout
        android:id="@+id/item_ayuda"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="5dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="25dp"
            android:src="@drawable/svg_question"
            app:tint="?colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="6dp"
            android:text="@string/item_ayuda"
            android:textSize="13sp"
            android:padding="5dp"
            android:textColor="?colorOnSurfaceVariant"
            android:gravity="center"
            android:fontFamily="@font/roboto_medium" />
    </LinearLayout>

    <View
        android:id="@+id/divider2"
        android:layout_width="140dp"
        android:layout_height="1dp"
        android:padding="5dp"
        android:layout_gravity="center"
        android:background="?color" />

    <LinearLayout
        android:id="@+id/item_cerarSesion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="5dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center">

        <ImageView
            android:layout_width="30dp"
            android:layout_height="25dp"
            android:src="@drawable/svg_logout"
            app:tint="?colorPrimary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:drawablePadding="6dp"
            android:text="@string/lbl_cerrarSesionBotton"
            android:textSize="13sp"
            android:padding="5dp"
            android:textColor="?colorOnSurfaceVariant"
            android:gravity="center"
            android:fontFamily="@font/roboto_medium"
            />
    </LinearLayout>



</LinearLayout>
