<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingBottom="10dp"
    android:background="@drawable/fondo_dialogo_login">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp"
        app:cardCornerRadius="20dp"
        android:layout_marginStart="80dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="80dp">

        <LinearLayout
            android:id="@+id/linearLayout21"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="10dp">

            <EditText
                android:id="@+id/titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                android:enabled="false"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center"
                android:hint="@string/titulo"
                android:inputType="text"
                android:paddingStart="6dp"
                android:paddingTop="6dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/title" />

            <TextView
                android:id="@+id/fecha"
                style="@style/Widget.AppCompat.EditText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="20dp"
                android:background="@android:color/transparent"
                android:clickable="false"
                android:fontFamily="@font/poppins_regular"
                android:hint="@string/fecha2"
                android:padding="6dp"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/subtitle" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardView"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:clickable="false"
                android:contentDescription="@string/tarjeta_del_planificador_para_iniciar_sesi_n"
                android:focusable="true"
                android:gravity="center"
                app:cardBackgroundColor="@color/whitish"
                app:cardCornerRadius="20dp"
                app:strokeColor="?color"
                app:strokeWidth="1.5dp">

                <ImageView
                    android:id="@+id/borrarIcon"
                    android:layout_width="33dp"
                    android:layout_height="33dp"
                    android:layout_alignParentEnd="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:contentDescription="@string/lbl_Consultas"
                    android:elevation="4dp"
                    app:srcCompat="@drawable/trash_image_svg" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imagen"
                    style="@style/addPhotoBackground"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_margin="15dp"
                    android:layout_weight="1"
                    android:clickable="false"
                    android:focusable="false" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>


    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/colors"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/card">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab1"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="60dp"
            android:layout_height="40dp"
            app:backgroundTint="@color/purpleCategoria"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            app:iconTint="?colorOnSurface"
            app:strokeWidth="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab2"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="60dp"
            android:layout_height="40dp"
            app:backgroundTint="@color/pinkCategoria"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            app:iconTint="?colorOnSurface"
            app:strokeWidth="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab3"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="60dp"
            android:layout_height="40dp"
            app:backgroundTint="@color/greenCategoria"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            app:iconTint="?colorOnSurface"
            app:strokeWidth="0dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/colors2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintStart_toStartOf="@+id/colors"
        app:layout_constraintTop_toBottomOf="@+id/colors">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab4"
            android:layout_width="60dp"
            android:layout_height="40dp"
            app:strokeWidth="0dp"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconTint="?colorOnSurface"
            app:backgroundTint="@color/yellowCategoria" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab5"
            android:layout_width="60dp"
            android:layout_height="40dp"
            app:strokeWidth="0dp"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconTint="?colorOnSurface"
            app:backgroundTint="#CDEDFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab6"
            android:layout_width="60dp"
            android:layout_height="40dp"
            app:strokeWidth="0dp"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconTint="?colorOnSurface"
            app:backgroundTint="?color" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_editar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_semibold"
        android:text="@string/editar"
        android:textAllCaps="false"
        android:textColor="@color/darkGreen"
        android:textSize="@dimen/button"
        app:icon="@drawable/svg_edit_outline"
        app:iconTint="@color/darkGreen"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/colors2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_borrar"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:fontFamily="@font/poppins_semibold"
        android:text="@string/borrar"
        android:textSize="@dimen/button"
        android:textAllCaps="false"
        app:icon="@drawable/svg_trash"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btn_editar" />

    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_margin="20dp"
        android:contentDescription="Cerrar seccion"
        android:background="@drawable/bg_close_button"
        android:src="@drawable/svg_close"
        android:padding="12dp"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>