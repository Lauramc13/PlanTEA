<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/widthDialog"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login"
    android:layout_margin="15dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="@dimen/paddingTopDialog"
        android:paddingBottom="15dp"
        app:layout_constraintTop_toBottomOf="@+id/icono_CerrarDialogo">

        <TextView
            android:id="@+id/lbl_Logout2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/poppins_bold"
            android:gravity="center"
            android:text="@string/lbl_eliminarPlanificacion"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/modalTitle" />

        <TextView
            android:id="@+id/lbl_Logout3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:fontFamily="@font/poppins_medium"
            android:gravity="center"
            android:text="@string/lbl_eliminarPlanificacionMensaje2"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/modalText" />


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:gravity="center"
            android:padding="10dp">

            <Button
                android:id="@+id/btn_cancelarPlan"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/lbl_cancelar"
                android:textColor="@color/darkGreen"
                android:textSize="@dimen/button"
                app:cornerRadius="25dp" />

            <Button
                android:id="@+id/btn_eliminarPlan"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/lbl_eliminar"
                android:textColor="@color/darkGreen"
                android:textSize="@dimen/button"
                app:cornerRadius="25dp" />

        </LinearLayout>


    </LinearLayout>

    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_margin="10dp"
        android:contentDescription="Cerrar seccion"
        android:background="@drawable/bg_close_button"
        android:src="@drawable/svg_close"
        android:padding="12dp"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>