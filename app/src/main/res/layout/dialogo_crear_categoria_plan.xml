<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login"
    android:padding="20dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_textinputedit">

                <ImageView
                    android:id="@+id/img_NuevoPicto"
                    style="@style/addPhotoBackground"
                    android:layout_width="140dp"
                    android:layout_margin="5dp"
                    android:layout_height="140dp"
                    android:contentDescription="Añadir imagen del planificador"
                    app:shapeAppearance="@style/cornerRadius" />
            </FrameLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/txt_Titulo"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="50dp"
                android:ems="10"
                android:inputType="text"
                android:textColor="?colorOnSurface"
                app:shapeAppearance="@style/cornerRadiusLogin">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/lbl_tulo"
                    android:inputType="text"
                    android:textColor="?colorOnSurface"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/txt_Password"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/color"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/modalText" />

            <LinearLayout
                android:id="@+id/colors"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@+id/txt_Titulo"
                app:layout_constraintStart_toStartOf="@+id/txt_Titulo"
                app:layout_constraintTop_toBottomOf="@+id/textView3">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab1"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="?colorOnSurface"
                    app:backgroundTint="@color/purpleCategoria" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab2"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="?colorOnSurface"
                    app:backgroundTint="@color/pinkCategoria" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab3"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="?colorOnSurface"
                    app:backgroundTint="@color/greenCategoria" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/colors2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="@+id/colors"
                app:layout_constraintTop_toBottomOf="@+id/colors">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab4"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="?colorOnSurface"
                    app:backgroundTint="@color/yellowCategoria" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab5"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="?colorOnSurface"
                    app:backgroundTint="#CDEDFF" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab6"
                    android:layout_width="70dp"
                    android:layout_height="60dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="?colorOnSurface"
                    app:backgroundTint="?color" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_GuardarPicto"
                style="@style/Widget.Material3.Button"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="@string/crear_categoria"
                android:textSize="14sp"
                android:textColor="#203130"
                app:cornerRadius="10dp"
                android:fontFamily="@font/poppins_semibold" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>