<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:tools="http://schemas.android.com/tools">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:id="@+id/card_plan"
        android:layout_height="50dp"
        style="@style/items"
        app:strokeColor="?color"
        app:strokeWidth="1.5dp"
        app:cardCornerRadius="20dp"
        android:layout_marginBottom="10dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/lbl_Planificacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/titleSmall"
                    android:padding="10dp"
                    android:gravity="center"
                    android:layout_marginLeft="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:textColor="?colorOnSurface"
                    android:text="Ejemplo plan"/>

                <TextView
                    android:id="@+id/separator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="17sp"
                    android:gravity="center"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="-"
                    android:textColor="?colorOnSurface"
                    android:visibility="gone"
                    tools:ignore="HardcodedText" />

                <TextView
                    android:id="@+id/lbl_Fecha"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/titleSmall"
                    android:padding="10dp"
                    android:gravity="center"
                    android:visibility="gone"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Ejemplo plan"/>


                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/icon_visibility"
                    android:layout_width="40dp"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_height="40dp"
                    app:iconSize="22dp"
                    app:iconTint="?colorOnSurface"
                    android:padding="8dp"
                    app:strokeWidth="0dp"
                    app:iconGravity="textStart"
                    android:visibility="gone"
                    app:icon="@drawable/svg_eye_on" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/icon_eye"
                    android:layout_width="40dp"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_height="40dp"
                    app:iconSize="18dp"
                    android:padding="8dp"
                    app:iconTint="?colorOnSurface"
                    app:strokeWidth="0dp"
                    app:iconGravity="textStart"
                    android:visibility="gone"
                    app:icon="@drawable/svg_open" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/icon_edit"
                    android:layout_width="40dp"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_height="wrap_content"
                    app:iconSize="24dp"
                    app:iconTint="?colorOnSurface"
                    android:padding="8dp"
                    app:strokeWidth="0dp"
                    app:iconGravity="textStart"
                    android:visibility="gone"
                    app:icon="@drawable/svg_edit_outline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/icon_export"
                    android:layout_width="40dp"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_height="wrap_content"
                    app:iconSize="24dp"
                    app:iconTint="?colorOnSurface"
                    android:padding="8dp"
                    app:strokeWidth="0dp"
                    android:layout_marginEnd="10dp"
                    app:iconGravity="textStart"
                    android:visibility="gone"
                    app:icon="@drawable/svg_export" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/icon_options"
                    android:layout_width="40dp"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_height="wrap_content"
                    app:iconSize="20dp"
                    app:iconTint="?colorOnSurface"
                    android:padding="8dp"
                    app:strokeWidth="0dp"
                    android:alpha="0.5"
                    app:iconGravity="textStart"
                    app:icon="@drawable/svg_options" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/items_planificacion"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="-10dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:visibility="visible"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>