<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:layout_editor_absoluteX="6dp"
    tools:layout_editor_absoluteY="0dp">

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="77dp"
        android:layout_height="75dp"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@+id/textView7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_register" />

    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="45dp"
        android:fontFamily="@font/montserrat_semibold"
        android:text="Registrarse"
        android:textColor="@color/teal_900"
        android:textSize="30sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.21" />

    <TextView
        android:id="@+id/textView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        android:fontFamily="@font/montserrat_medium"
        android:text="Datos del planificador"
        android:textColor="@color/teal_900"

        android:textSize="20sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.276" />

    <EditText
        android:id="@+id/txt_Name"
        android:layout_width="350dp"
        android:layout_height="50dp"
        android:layout_marginTop="17dp"
        android:background="@drawable/fondo_texto_login"
        android:ems="10"
        android:fontFamily="@font/montserrat_regular"
        android:hint="Nombre"
        android:inputType="text"
        android:paddingStart="15dp"
        android:textColor="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.326" />

    <EditText
        android:id="@+id/txt_UserName"
        android:layout_width="350dp"
        android:layout_height="50dp"
        android:layout_marginTop="17dp"
        android:background="@drawable/fondo_texto_login"
        android:ems="10"
        android:fontFamily="@font/montserrat_regular"
        android:hint="Nombre de usuario"
        android:inputType="text"
        android:paddingStart="15dp"
        android:textColor="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_Name"
        app:layout_constraintVertical_bias="0.004" />

    <EditText
        android:id="@+id/txt_password"
        android:layout_width="350dp"
        android:layout_height="50dp"
        android:layout_marginTop="17dp"
        android:background="@drawable/fondo_texto_login"
        android:ems="10"
        android:fontFamily="@font/montserrat_regular"
        android:hint="Contraseña"
        android:inputType="textPassword"
        android:paddingStart="15dp"
        android:textColor="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_UserName"
        app:layout_constraintVertical_bias="0.014" />

    <EditText
        android:id="@+id/txt_password2"
        android:layout_width="350dp"
        android:layout_height="50dp"
        android:layout_marginTop="17dp"
        android:background="@drawable/fondo_texto_login"
        android:ems="10"
        android:fontFamily="@font/montserrat_regular"
        android:hint="Vuelve a repetir la contraseña"
        android:inputType="textPassword"
        android:paddingStart="15dp"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_password"
        app:layout_constraintVertical_bias="0.258" />

    <EditText
        android:id="@+id/txt_objeto"
        android:layout_width="350dp"
        android:layout_height="50dp"
        android:background="@drawable/fondo_texto_login"
        android:ems="10"
        android:layout_marginTop="17dp"
        android:fontFamily="@font/montserrat_regular"
        android:hint="Objeto tranquilizador"
        android:inputType="text"
        android:paddingStart="15dp"
        android:textColor="@color/black"
        app:layout_constraintBottom_toTopOf="@+id/check_Plaificado"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_password2"
        app:layout_constraintVertical_bias="0.258" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/check_Plaificado"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="47dp"
        android:fontFamily="@font/montserrat_medium"
        android:text="Datos del planificado"
        android:textColor="@color/black"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_objeto" />

<EditText
        android:id="@+id/txt_nombreplanificado"
        android:layout_width="350dp"
        android:layout_height="50dp"
        android:background="@drawable/fondo_texto_login"
        android:ems="10"
        android:fontFamily="@font/montserrat_regular"
        android:hint="Nombre"
        android:layout_marginTop="17dp"
        android:inputType="text"
        android:paddingStart="15dp"
        android:textColor="@color/black"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/check_Plaificado"
         />

    <Button
        android:id="@+id/btn_register"
        android:layout_width="186dp"
        android:layout_height="52dp"
        android:layout_marginBottom="20dp"
        android:backgroundTint="#80cbc4"
        android:layout_marginTop="17dp"
        android:fontFamily="@font/montserrat_semibold"
        android:text="Crear cuenta"
        android:textColor="#203130"
        app:cornerRadius="25dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txt_nombreplanificado"
        app:layout_constraintVertical_bias="0.011" />


</androidx.constraintlayout.widget.ConstraintLayout>