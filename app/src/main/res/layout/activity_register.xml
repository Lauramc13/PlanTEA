<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?colorBG0"
    tools:layout_editor_absoluteX="6dp"
    tools:layout_editor_absoluteY="0dp"
    tools:context=".presentacion.actividades.RegisterActivity">


    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.35"
        android:layout_height="wrap_content"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob_v2"
        android:scaleType="centerCrop"
        android:alpha="0.5"
        app:tint="?colorPrimary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp">

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="77dp"
            android:layout_height="75dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintBottom_toTopOf="@+id/textView7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:srcCompat="@drawable/svg_register" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="15dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/lbl_registrarse"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.21" />

        <ScrollView
        android:id="@+id/scrollRegister"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/lbl_datosPlanificador"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/subtitle" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Name"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            style="@style/cornertextInput"
            android:ems="10"
            android:hint="@string/lbl_datosNombre"
            android:inputType="text">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="text"
                style="@style/textInput"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Email"
            style="@style/cornertextInput"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:ems="10"
            android:hint="@string/lbl_email"
            android:inputType="text">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="text"
                style="@style/textInput"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_UserName"
            style="@style/cornertextInput"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:ems="10"
            android:hint="@string/lbl_nombreUsuario"
            android:inputType="text">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="text"
                style="@style/textInput"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_password"
            style="@style/cornertextInput"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:ems="10"
            android:hint="@string/lbl_contrasena"
            android:inputType="textPassword"
            android:textColor="?colorOnSurface"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="textPassword"
                style="@style/textInput"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_password2"
            style="@style/cornertextInput"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:ems="10"
            android:hint="@string/lbl_datosContraseña"
            android:inputType="textPassword"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="textPassword"
                style="@style/textInput"/>
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_register"
            android:layout_width="280dp"
            android:layout_height="52dp"
            android:layout_marginTop="35dp"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/lbl_crearCuenta"
            style="@style/Widget.Material3.Button"
            android:textSize="@dimen/button"
            android:textColor="@color/darkGreen" />
    </LinearLayout>
    </ScrollView>

    </LinearLayout>

    <Button
        android:id="@+id/goBackButton"
        style="@style/Widget.Material3.Button.IconButton.Filled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cornerRadius="25dp"
        app:icon="@drawable/svg_go_back"
        app:iconSize="35dp"
        app:iconTint="?colorOnSurface"
        app:backgroundTint="@color/transparent" />
</androidx.constraintlayout.widget.ConstraintLayout>