<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?colorBG0"
    tools:layout_editor_absoluteX="6dp"
    tools:layout_editor_absoluteY="0dp"
    tools:context=".presentacion.actividades.RegisterActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.3"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.2"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob3"
        android:scaleType="centerCrop"
        app:tint="?colorPrimary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="50dp"

        tools:layout_editor_absoluteX="0dp"
        tools:layout_editor_absoluteY="0dp">

        <ImageView
            android:id="@+id/imageView3"
            android:layout_width="77dp"
            android:layout_height="75dp"
            android:layout_marginBottom="10dp"
            app:layout_constraintBottom_toTopOf="@+id/textView7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:srcCompat="@drawable/svg_register" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="15dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/lbl_registrarse"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.21" />

        <ScrollView
        android:id="@+id/scrollRegister"
        android:layout_width="match_parent"
        android:layout_height="match_parent">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textView8"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/lbl_datosPlanificador"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/subtitle"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.21" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Name"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:background="@drawable/fondo_texto_login"
            android:ems="10"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_datosNombre"
            android:inputType="text"
            android:textColor="?colorOnSurface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.326"
            app:shapeAppearance="@style/cornerRadiusLogin"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="text"
                android:textColor="?colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Email"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:background="@drawable/fondo_texto_login"
            android:ems="10"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_email"
            android:inputType="text"
            android:textColor="?colorOnSurface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_Name"
            app:layout_constraintVertical_bias="0.004"
            app:shapeAppearance="@style/cornerRadiusLogin"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="text"
            android:textColor="?colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_UserName"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:background="@drawable/fondo_texto_login"
            android:ems="10"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_nombreUsuario"
            android:inputType="text"
            android:textColor="?colorOnSurface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_Name"
            app:layout_constraintVertical_bias="0.004"
            app:shapeAppearance="@style/cornerRadiusLogin"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="text"
            android:textColor="?colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_password"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:background="@drawable/fondo_texto_login"
            android:ems="10"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_contrasena"
            android:inputType="textPassword"
            android:textColor="?colorOnSurface"
            app:endIconMode="password_toggle"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_UserName"
            app:layout_constraintVertical_bias="0.014"
            app:shapeAppearance="@style/cornerRadiusLogin">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="textPassword"
                android:textColor="?colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_password2"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:background="@drawable/fondo_texto_login"
            android:ems="10"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_datosContraseña"
            android:inputType="textPassword"
            android:textColor="?colorOnSurface"
            app:endIconMode="password_toggle"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/txt_password"
            app:layout_constraintVertical_bias="0.258"
            app:shapeAppearance="@style/cornerRadiusLogin">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="textPassword"
                android:textColor="?colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <androidx.appcompat.widget.SwitchCompat
            app:theme="@style/Switches"
            style="@style/Widget.Material3.CompoundButton.MaterialSwitch"
            android:id="@+id/check_Objeto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="47dp"
            android:layout_marginBottom="17dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/lbl_configuracion_objeto"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="68dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/txt_objeto"
                android:layout_width="280dp"
                android:layout_height="60dp"
                android:layout_centerInParent="true"
                android:layout_centerHorizontal="true"
                android:background="@drawable/fondo_texto_login"
                android:enabled="false"
                android:fontFamily="@font/poppins_regular"
                android:hint="@string/lbl_configuracion_objeto"
                android:inputType="text"
                android:textColor="?colorOnSurface"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"                app:shapeAppearance="@style/cornerRadiusLogin">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:inputType="text"
                    android:textColor="?colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAyudaActividad"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="60dp"
                android:layout_marginTop="11dp"
                android:layout_toRightOf="@id/txt_objeto"
                android:gravity="center"
                app:cornerRadius="25dp"
                app:icon="@drawable/question_simple"
                app:iconSize="20dp"
                app:iconTint="#181F25" />

            <RelativeLayout
                android:id="@+id/relativeLayoutTooltip"
                android:layout_width="430dp"
                android:layout_height="68dp">

                <TextView
                    android:id="@+id/tooltipText"
                    android:layout_width="320dp"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="2dp"
                    android:layout_marginBottom="2dp"
                    android:layout_marginEnd="52dp"
                    android:background="@drawable/fragment_personalizado"
                    android:padding="13dp"
                    android:textSize="@dimen/caption"
                    android:text="@string/explicacion_actividad"
                    android:textColor="?colorOnSurface"
                    android:theme="@style/cards2"
                    android:visibility="gone" />

            </RelativeLayout>

        </RelativeLayout>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/check_Plaificado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="47dp"
            android:fontFamily="@font/poppins_medium"
            android:text="@string/lbl_datosPlanificado"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/subtitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:theme="@style/Switches"
            style="@style/Widget.Material3.CompoundButton.MaterialSwitch" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_nombreplanificado"
            android:layout_width="280dp"
            android:layout_height="60dp"
            android:layout_marginTop="17dp"
            android:background="@drawable/fondo_texto_login"
            android:ems="10"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_datosNombre"
            android:inputType="text"
            android:textColor="?colorOnSurface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/textView9"
            app:layout_constraintVertical_bias="0.258"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"            app:shapeAppearance="@style/cornerRadiusLogin">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="text"
                android:textColor="?colorOnSurface" />
        </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/btn_register"
            android:layout_width="280dp"
            android:layout_height="52dp"
            android:layout_marginTop="35dp"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/lbl_crearCuenta"
            style="@style/Widget.Material3.Button"
            android:textSize="@dimen/button"
            android:textColor="#203130"
            app:cornerRadius="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txt_Password"
            app:layout_constraintVertical_bias="0.011" />
    </LinearLayout>
    </ScrollView>

    </LinearLayout>

    <Button
        android:id="@+id/goBackButton"
        style="@style/Widget.Material3.Button.IconButton.Filled"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cornerRadius="25dp"
        app:icon="@drawable/svg_go_back"
        app:iconSize="35dp"
        app:iconTint="?colorOnSurface"
        app:backgroundTint="@color/transparent" />
</androidx.constraintlayout.widget.ConstraintLayout>