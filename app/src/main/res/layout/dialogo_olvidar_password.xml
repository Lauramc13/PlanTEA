<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login"
    android:padding="20dp">

        <LinearLayout
            android:id="@+id/linearLayout8"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imageView3"
                android:layout_width="65dp"
                android:layout_height="64dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                app:srcCompat="@drawable/svg_key" />

            <TextView
                android:id="@+id/lbl_Logout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:gravity="center"
                android:layout_marginBottom="10dp"
                android:text="@string/lbl_contraseniaOlvidada"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/modalTitle" />

            <TextView
                android:id="@+id/lbl_otro"
                android:layout_width="300dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_medium"
                android:gravity="center"
                android:text="¡No hay problema! Te enviaremos una nueva contraseña"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/modalText" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/txt_Email"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="250dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:contentDescription="Campo de texto nombre de usuario"
                android:fontFamily="@font/poppins_regular"
                android:hint="@string/lbl_email"
                android:inputType="text"
                android:textColor="?colorOnSurface"
                app:shapeAppearance="@style/cornerRadiusLogin">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:inputType="text"
                    android:textColor="?colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <Button
                android:id="@+id/btn_enviar"
                style="@style/Widget.Material3.Button"
                android:layout_width="250dp"
                android:layout_height="52dp"
                android:layout_marginTop="15dp"
                android:layout_marginBottom="40dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="ENVIAR CORREO"
                android:textColor="#203130"
                app:cornerRadius="10dp"
                android:textSize="@dimen/button" />

        </LinearLayout>

    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_baseline_close_24"
        android:contentDescription="@string/cerrar_dialogo" />

</androidx.constraintlayout.widget.ConstraintLayout>