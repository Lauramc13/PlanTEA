        <TextView
            android:id="@+id/lbl_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Titulo"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/titleSmall"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_fecha" />

        <TextView
            android:id="@+id/lbl_mensajeNinio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/lbl_mensajeNinio"
            android:fontFamily="@font/poppins_regular"
            android:text="@string/lbl_mensajeNinio"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/subtitle"
            android:gravity="center"
            android:visibility="invisible"
            app:layout_constraintBottom_toBottomOf="@id/constraintLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/constraintLayout" />

        <TextView
            android:id="@+id/lbl_importante"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/importante"
            android:textColor="@color/red"
            android:visibility="gone"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="15sp"
            android:layout_marginBottom="-10dp"
            app:layout_constraintBottom_toTopOf="@+id/recycler_plan"
            tools:ignore="MissingConstraints" />
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_plan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:contentDescription="Lista con la planificación actual"
            android:scrollbars="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lbl_titulo"
            app:layout_constraintVertical_bias="0.0" />

        <Button
            android:id="@+id/crearPlan"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/lbl_nuevoEvento"
            android:textColor="#203130"
            android:textSize="@dimen/button"
            android:visibility="invisible"
            android:textAllCaps="true"
            app:cornerRadius="25dp"
            android:layout_marginTop="20dp"
            app:icon="@drawable/ic_baseline_add_24"
            app:iconSize="25dp"
            app:iconTint="#203130"
            app:layout_constraintTop_toBottomOf="@id/lbl_mensajeNinio"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>


