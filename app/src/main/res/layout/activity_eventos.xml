<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?customBgColor"
    tools:context=".presentacion.actividades.EventosActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob3"
        app:tint="?subColorBackground" />

    <ImageView
        android:id="@+id/imageDecoration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_blob" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintHeight_percent="0.7"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_marginBottom="10dp"
        app:layout_constraintBottom_toTopOf="@+id/fragmentContainerViewBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fragmentContainerView">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_cards_configuracion">

        <LinearLayout
            android:id="@+id/layout_fecha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:contentDescription="Mes y flechas de navegación atras/delante"
            android:orientation="horizontal"
            app:cornerRadius="25dp"
            android:layout_marginTop="15dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/lbl_dia"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginEnd="10dp"
                android:maxLines="2"
                android:autoSizeTextType="uniform"
                android:fontFamily="@font/poppins_bold"
                android:text="Viernes, 9 de septiembre"
                android:textColor="?colorTertiary"
                android:textSize="@dimen/subtitle" />

            <Button
                android:id="@+id/CalendarDate"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Botón calendario"
                android:gravity="center"
                app:cornerRadius="25dp"
                app:icon="@drawable/svg_calendardate"
                app:iconSize="26dp"
                app:iconTint="?colorOnSurface">

            </Button>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/recycler_plan">

            <Button
                android:id="@+id/icon_deshacerTodas"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="50dp"
                android:layout_height="45dp"
                android:layout_marginEnd="5dp"
                android:contentDescription="Botón reproducir lista"
                android:enabled="false"
                android:textColor="#203130"
                android:textSize="20sp"
                android:theme="@style/botonesSecundarios"
                app:cornerRadius="25dp"
                app:icon="@drawable/svg_rewind"
                app:iconGravity="textEnd"
                app:iconSize="22dp"
                app:iconTint="#203130" />

            <Button
                android:id="@+id/icon_deshacer"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:elevation="0dp"
                android:layout_width="45dp"
                android:layout_height="45dp"
                android:layout_marginEnd="5dp"
                android:contentDescription="Botón reproducir lista"
                android:textColor="#203130"
                android:textSize="20sp"
                android:theme="@style/botonesSecundarios"
                app:cornerRadius="25dp"
                android:enabled="false"
                app:icon="@drawable/svg_play_goback"
                app:iconGravity="textEnd"
                app:iconSize="20dp"
                app:iconTint="#203130" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/icon_reproducir"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:elevation="0dp"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="Botón reproducir lista"
                android:textColor="#203130"
                android:textSize="20sp"
                app:cornerRadius="100dp"
                android:enabled="true"
                app:icon="@drawable/svg_play"
                app:iconGravity="textEnd"
                app:iconSize="25dp"
                app:iconTint="#203130" />

            <Button
                android:id="@+id/icon_marcar"
                android:layout_width="45dp"
                android:layout_height="45dp"
                app:elevation="0dp"
                android:layout_marginStart="5dp"
                android:contentDescription="Botón reproducir lista"
                android:textColor="#203130"
                android:textSize="20sp"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:theme="@style/botonesSecundarios"
                app:cornerRadius="25dp"
                app:icon="@drawable/svg_play_gofoward"
                app:iconSize="20dp"
                app:iconTint="#203130" />

            <Button
                android:id="@+id/icon_marcarTodas"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_marginStart="5dp"
                android:elevation="0dp"
                android:layout_width="50dp"
                android:layout_height="45dp"
                android:contentDescription="Botón reproducir lista"
                android:textColor="#203130"
                android:textSize="20sp"
                android:theme="@style/botonesSecundarios"
                app:cornerRadius="25dp"
                app:icon="@drawable/svg_foward"
                app:iconGravity="textEnd"
                app:iconSize="22dp"
                app:iconTint="#203130"  />
        </LinearLayout>

        <!--<Button
            android:id="@+id/icon_escuchar"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="180dp"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
