<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?backgroundColor"
    tools:context=".presentacion.actividades.TraductorActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/blob3"
        app:tint="?subColorBackground" />

    <ImageView
        android:id="@+id/imageView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_blob"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toTopOf="@+id/fragmentContainerViewBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fragmentContainerView">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textoTraducir"
                style="@style/backgroundTraduccion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_cuaderno_tiempo"

                android:layout_margin="5dp"
                android:layout_weight="1"
                android:hint="Escribe tu frase aqui..."
                android:inputType="text"
                android:textColor="?colorOnSurface"
                app:boxBackgroundColor="@android:color/transparent"
                app:hintTextColor="?colorAccent">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:textColor="?colorOnSurface"
                    android:textSize="@dimen/subtitle" />
            </com.google.android.material.textfield.TextInputLayout>

        <Button
            android:id="@+id/traducirButton"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="140dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:fontFamily="@font/poppins_semibold"
            android:text="TRADUCIR"
            android:textColor="#203130"
            android:textSize="@dimen/button"
            app:cornerRadius="25dp" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/fondo_cuaderno_tiempo">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_plan"
                android:layout_width="match_parent"
                android:layout_height="135dp"
                android:layout_margin="20dp"
                android:contentDescription="Lista con la planificación actual"
                android:scrollbars="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0" />

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="20dp"
                android:layout_marginStart="20dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/recycler_plan" />

            <Button
                android:id="@+id/guardarButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:visibility="invisible"
                android:fontFamily="@font/poppins_semibold"
                android:text="GUARDAR"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/button"
                app:cornerRadius="25dp"
                app:icon="@drawable/ic_baseline_save_24"
                app:iconSize="25dp"
                app:iconTint="?colorOnSurface"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/recycler_plan"
                app:layout_constraintVertical_bias="0.0" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical"
            android:gravity="center">
            <Button
                android:id="@+id/escucharButtonPalabra"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="270dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/str_escuchar"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/button"
                app:cornerRadius="25dp"
                android:backgroundTint="?configuracionCardBg"
                app:icon="@drawable/svg_sound"
                app:iconSize="25dp"
                app:iconTint="?colorOnSurface" />

            <Button
                android:id="@+id/escucharButtonFrase"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="270dp"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/str_escucharFrase"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/button"
                android:backgroundTint="?configuracionCardBg"
                app:cornerRadius="25dp"
                app:icon="@drawable/svg_sound"
                app:iconSize="25dp"
                app:iconTint="?colorOnSurface" />

        </LinearLayout>
    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerView"
        android:name="com.example.plantea.presentacion.fragmentos.NavigationTopFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerViewBottom"
            android:name="com.example.plantea.presentacion.fragmentos.NavigationBottomFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>