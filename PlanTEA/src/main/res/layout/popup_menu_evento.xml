<!-- res/layout/custom_popup_cuaderno.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="2dp"
    android:background="@drawable/bg_popup_info">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/item_visibilidad"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="25dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_eye_filled"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/item_ver"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="23dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_open"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/item_editar"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="23dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_edit_filled"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/item_export"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="25dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_export"/>

</LinearLayout>
