<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/widthDialogSmall"
    android:layout_height="wrap_content"
    android:paddingBottom="10dp"
    android:id="@+id/dialogo_fecha_tea"
    android:background="@drawable/fondo_dialogo_login">

        <LinearLayout
            android:id="@+id/linearLayout21"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="30dp">

            <TextView
                android:id="@+id/titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/titulo"
                android:paddingStart="6dp"
                android:paddingTop="6dp"
                android:paddingEnd="6dp"
                android:paddingBottom="2dp"
                android:gravity="center"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/displaySmall" />

            <TextView
                android:id="@+id/fecha"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="20dp"
                android:clickable="false"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/fecha2"
                android:padding="6dp"
                android:gravity="center"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/title" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardView"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:clickable="false"
                android:focusable="true"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/whitish"
                app:cardCornerRadius="20dp"
                app:strokeColor="?color"
                app:strokeWidth="1.5dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/imagen"
                    style="@style/addPhotoBackground"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_margin="15dp"
                    android:layout_weight="1"
                    android:clickable="false"
                    android:focusable="false" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_margin="15dp"
        android:contentDescription="Cerrar seccion"
        android:background="@drawable/bg_close_button"
        android:src="@drawable/svg_close"
        android:padding="12dp"
        android:alpha="0.9"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>