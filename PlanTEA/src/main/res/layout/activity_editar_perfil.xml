<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="?configuracionCardBg">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerView"
        android:name="com.example.plantea.presentacion.fragmentos.NavigationTopFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:srcCompat="@drawable/svg_blob" />

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob_v2"
        app:tint="?subColorBackground" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="vertical"
        android:layout_marginEnd="40dp"
        android:layout_marginStart="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUsuario"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:clickable="true"
            android:contentDescription="@string/tarjeta_del_planificador_para_iniciar_sesi_n"
            android:focusable="true"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            style="@style/cardBackground">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imagenUsuario"
                style="@style/addPhotoBackground"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:background="@drawable/svg_add_image"
                android:clickable="false"
                android:focusable="false" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_nombrePlanificador"
            style="@style/cornertextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:contentDescription="Campo de texto con nombre del planificador"
            android:ems="10"
            android:hint="@string/lbl_datosNombre"
            android:inputType="textPersonName"
            android:maxLength="14"
            android:textCursorDrawable="@null">

            <com.google.android.material.textfield.TextInputEditText
                style="@style/textInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:cursorVisible="true"
                android:maxLength="50"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_correoPlanificador"
            style="@style/cornertextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:contentDescription="Campo de texto con correo del planificador"
            android:ems="10"
            android:enabled="false"
            android:hint="@string/lbl_email"
            android:inputType="textPersonName"
            android:maxLength="14"
            android:textCursorDrawable="@null">

            <com.google.android.material.textfield.TextInputEditText
                style="@style/textInput"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.7"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonContrasenia"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="10dp"
            android:contentDescription="Boton para cambiar contraseña del usuario"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/btn_CambiarPass"
            android:textAllCaps="false"
            android:textSize="@dimen/button"
            app:cornerRadius="25dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonGuardar"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_marginTop="50dp"
            android:contentDescription="Boton para cambiar contraseña del usuario"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/btn_Guardar"
            android:textAllCaps="false"
            android:textColor="@color/darkGreen"
            android:textSize="@dimen/button"
            app:cornerRadius="25dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>