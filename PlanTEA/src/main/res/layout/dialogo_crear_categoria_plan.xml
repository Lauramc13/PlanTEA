<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/fondo_dialogo_login"
    android:padding="20dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_textinputedit">

                <ImageView
                    android:id="@+id/img_NuevoPicto"
                    style="@style/addPhotoBackground"
                    android:layout_width="210dp"
                    android:layout_margin="9dp"
                    android:layout_height="140dp"
                    app:shapeAppearance="@style/cornerRadius" />
            </FrameLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/txt_Titulo"
                style="@style/cornertextInput"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="50dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="50dp"
                android:ems="10"
                android:inputType="text"
                android:textColor="?colorOnSurface"
                app:shapeAppearance="@style/cornerRadiusLogin">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/lbl_tulo"
                    android:inputType="text"
                    style="@style/textInput"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/categoria_para"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/modalText"
                app:layout_constraintStart_toStartOf="@+id/txt_Titulo"
                app:layout_constraintTop_toBottomOf="@+id/txt_Titulo" />

            <FrameLayout
                android:id="@+id/frame_usuarios"
                android:layout_width="220dp"
                android:layout_height="52dp"
                android:layout_marginTop="5dp"
                app:layout_constraintStart_toStartOf="@+id/textView4"
                app:layout_constraintTop_toBottomOf="@+id/textView4">

                <Spinner
                    android:id="@+id/spinner_Usuarios"
                    style="@style/dropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/border_spinner"
                    android:fontFamily="@font/poppins_regular"
                    android:popupBackground="@drawable/custom_popup_background_main"
                    android:spinnerMode="dropdown"
                    android:textColor="?colorOnSurface" />

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end|bottom"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@null"
                    android:src="@drawable/svg_arrow_down" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/color"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/modalText" />

            <LinearLayout
                android:id="@+id/colors"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@+id/txt_Titulo"
                app:layout_constraintStart_toStartOf="@+id/txt_Titulo"
                app:layout_constraintTop_toBottomOf="@+id/textView3">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab1"
                    android:layout_width="70dp"
                    android:layout_height="50dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="@color/md_theme_light_shadow"
                    app:backgroundTint="?colorPurple" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab2"
                    android:layout_width="70dp"
                    android:layout_height="50dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="@color/md_theme_light_shadow"
                    app:backgroundTint="?colorPink" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab3"
                    android:layout_width="70dp"
                    android:layout_height="50dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="@color/md_theme_light_shadow"
                    app:backgroundTint="?colorGreen" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/colors2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintStart_toStartOf="@+id/colors"
                app:layout_constraintTop_toBottomOf="@+id/colors">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab4"
                    android:layout_width="70dp"
                    android:layout_height="50dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="@color/md_theme_light_shadow"
                    app:backgroundTint="?colorYellow" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab5"
                    android:layout_width="70dp"
                    android:layout_height="50dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="@color/md_theme_light_shadow"
                    app:backgroundTint="?colorBlue" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/fab6"
                    android:layout_width="70dp"
                    android:layout_height="50dp"
                    app:strokeWidth="0dp"
                    app:cornerRadius="15dp"
                    app:iconGravity="textStart"
                    style="@style/Widget.Material3.Button.IconButton"
                    app:iconTint="?colorOnSurface"
                    app:backgroundTint="?color" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_GuardarPicto"
                style="@style/Widget.Material3.Button"
                android:layout_width="220dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="@string/crear_categoria"
                android:textSize="@dimen/button"
                android:textColor="@color/darkGreen"
                android:fontFamily="@font/poppins_semibold" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>