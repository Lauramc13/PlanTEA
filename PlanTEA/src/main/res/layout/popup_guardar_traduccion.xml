<!-- res/layout/custom_popup_cuaderno.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="5dp"
    android:paddingBottom="5dp"
    android:background="@drawable/bg_popup_traduccion">

    <TextView
        android:id="@+id/item_planificacion"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawablePadding="8dp"
        android:text="@string/planificaci_n"
        android:height="44dp"
        android:textSize="13sp"
        android:gravity="center"
        android:padding="10dp"
        android:fontFamily="@font/roboto_medium"
        android:clickable="true"
        android:textColor="?colorOnSurface"
        app:drawableTint="?colorOnSurfaceVariant"
        app:drawableLeftCompat="@drawable/svg_plan2" />

    <com.google.android.material.divider.MaterialDivider
        android:layout_width="match_parent"
        android:layout_height="wrap_content"

        app:dividerColor="?color"/>

    <TextView
        android:id="@+id/item_pdf"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:drawablePadding="8dp"
        android:text="@string/pdf"
        android:textSize="13sp"
        android:height="44dp"
        android:padding="10dp"
        android:textColor="?colorOnSurface"
        android:gravity="center"
        android:layout_marginEnd="30dp"
        android:fontFamily="@font/roboto_medium"
        android:clickable="true"
        app:drawableTint="?colorOnSurfaceVariant"
        app:drawableLeftCompat="@drawable/svg_pdf" />
</LinearLayout>
