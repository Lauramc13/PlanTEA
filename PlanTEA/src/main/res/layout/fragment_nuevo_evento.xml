<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/btn_desplegar"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2dp"
    android:background="@drawable/bg_bottom_sheet">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/lbl_nuevoEvento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_gravity="top|center_horizontal"
        android:text="@string/lbl_nuevoEvento"
        android:fontFamily="@font/poppins_semibold"
        android:textAlignment="center"
        android:textColor="?colorOnSurface"
        android:textSize="@dimen/title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="65dp"
        android:padding="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="15dp"
            android:orientation="vertical">

                <!--<EditText
                    android:id="@+id/txt_tituloEvento"
                    android:hint="Titulo"
                    android:theme="@style/AppTheme.CursorBubble"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_regular"
                    android:layout_gravity="center_vertical|end"
                    android:textColor="?colorOnSurface"
                    android:inputType="textCapSentences"
                    style="@style/cornerRadiusEvento"
                    android:layout_marginBottom="10dp"
                    android:textSize="20sp" />-->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="3dp"

                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:padding="2dp"
                    android:src="@drawable/svg_calendar" />

                <TextView
                    android:id="@+id/textView11"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fecha"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="?colorOnSurface"
                    android:textSize="@dimen/formText" />

                <TextView
                    android:id="@+id/lbl_fechaEvento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="29 noviembre 2021"
                    android:fontFamily="@font/poppins_regular"
                    android:textAlignment="viewEnd"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:padding="2dp"
                    android:src="@drawable/svg_clock"/>

                <TextView
                    android:id="@+id/lbl_hora"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:layout_height="wrap_content"
                    android:text="@string/hora"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="@dimen/formText" />

                <TextView
                    android:id="@+id/btn_horaEvento"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:hint="@string/selecciona_hora"
                    android:gravity="end"
                    android:contentDescription="Boton seleccionar hora"
                    android:textSize="15sp"
                    android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>




            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:padding="2dp"
                    android:src="@drawable/svg_bell"/>

                <TextView
                    android:id="@+id/lbl_recordatorio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recordatorio"
                    android:layout_marginStart="10dp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="@dimen/formText" />


                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_recordatorio"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:enabled="true"
                    android:theme="@style/Switches" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:padding="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:padding="2dp"
                    android:src="@drawable/svg_eye_on"/>

                <TextView
                    android:id="@+id/lbl_hacer_visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hacer_visible_5_min_antes"
                    android:layout_marginStart="10dp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="@dimen/formText" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_hacer_visible"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:theme="@style/Switches" />
            </LinearLayout>

            <androidx.fragment.app.FragmentContainerView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:id="@+id/fragment_container_view"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>


            <!-- <Button
                android:id="@+id/button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:text="Planificar"
                android:textColor="@color/darkGreen"
                app:cornerRadius="25dp" /> -->

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/lbl_mensajePlanes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:paddingTop="30dp"
                    android:paddingBottom="30dp"
                    android:text="@string/lbl_mensaje"
                    android:textColor="?colorOnSurface"
                    android:textSize="15sp"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_planificacionesDisponibles" />

                <TextView
                    android:id="@+id/lbl_planificacionesDisponibles"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:fontFamily="@font/poppins_regular"
                    android:text="@string/planificaciones_disponibles"
                    android:textColor="?colorOnSurface"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/recycler_planificaciones2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/lbl_planificacionesDisponibles">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recycler_planificaciones"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintBottom_toBottomOf="parent"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            app:layout_constraintHeight_default="wrap"
                            app:layout_constraintHeight_max="200dp"
                            android:layout_marginTop="10dp" />

                </androidx.constraintlayout.widget.ConstraintLayout>

                <!--<Button
                    android:id="@+id/btn_planificar"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:contentDescription="Boton nueva planificación"
                    android:drawableLeft="@drawable/svg_add"
                    android:drawableTint="?colorOnSurface"
                    android:fontFamily="@font/poppins_semibold"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="@string/lbl_nuevaPlanificacion"
                    android:textColor="?colorOnSurface"
                    android:textSize="13sp"
                    app:cornerRadius="25dp"
                    app:iconGravity="textStart"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>-->
            </androidx.constraintlayout.widget.ConstraintLayout>

            <LinearLayout
                android:id="@+id/linearLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_borrarEvento"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/lbl_eliminar"
                    android:textColor="?colorOnSurface"
                    android:textSize="@dimen/button"
                    android:visibility="gone"
                    app:cornerRadius="25dp"
                    app:iconPadding="10dp"
                    android:layout_marginEnd="10dp"
                    app:icon="@drawable/svg_trash"
                    app:iconGravity="textStart"
                    app:iconTint="?colorOnSurface" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_guardarEvento"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:enabled="false"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/btn_Guardar"
                    android:textColor="@color/darkGreen"
                    android:textSize="@dimen/button"
                    app:cornerRadius="25dp"
                    app:icon="@drawable/svg_save"
                    app:iconGravity="textStart"
                    app:iconPadding="10dp"
                    app:iconSize="20dp"
                    android:layout_gravity="center"
                    app:iconTint="@color/darkGreen" />

            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <ImageView
        android:id="@+id/img_cancelarEvento"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_gravity="end"
        android:layout_margin="10dp"
        android:padding="12dp"
        android:visibility="gone"
        android:background="@drawable/bg_close_button"
        android:contentDescription="Cerrar configuración nuevo evento"
        app:srcCompat="@drawable/svg_close" />


</FrameLayout>