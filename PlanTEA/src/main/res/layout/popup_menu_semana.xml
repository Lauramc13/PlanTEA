<!-- res/layout/custom_popup_cuaderno.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="60dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="5dp"
    android:background="@drawable/bg_popup_info">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/item_link"
        style="@style/buttonInfo"
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:iconSize="25dp"
        android:padding="0dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_link"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/item_borrar"
        style="@style/buttonInfo"
        android:layout_width="50dp"
        android:layout_height="50dp"
        app:iconSize="25dp"
        android:padding="0dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_trash"/>

</LinearLayout>
