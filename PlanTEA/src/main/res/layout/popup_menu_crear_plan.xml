<!-- res/layout/custom_popup_cuaderno.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="2dp"
    android:background="@drawable/bg_popup_info">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/item_historia"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="25dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_text_filled"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/item_duracion"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="25dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_timer_filled"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/item_entretenimiento"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="25dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_game"/>

</LinearLayout>
