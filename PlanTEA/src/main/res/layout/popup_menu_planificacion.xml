<!-- res/layout/custom_popup_cuaderno.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="2dp"
    android:background="@drawable/bg_popup_info">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/icon_downloadPDF"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="25dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_download"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/icon_copy"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="25dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_files"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/icon_edit"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="23dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_edit_outline"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/icon_delete"
        style="@style/buttonInfo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        app:iconSize="25dp"
        app:iconGravity="textStart"
        app:icon="@drawable/svg_trash"/>

</LinearLayout>
