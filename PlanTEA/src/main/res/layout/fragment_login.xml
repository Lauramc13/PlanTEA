<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_bottom_sheet"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/linearLayout8"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:layout_marginTop="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_max="350dp"
        app:layout_constraintWidth_percent="0.8">

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Email"
            style="@style/cornertextInput"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:contentDescription="Campo de texto nombre de usuario"
            android:ems="10"
            android:hint="@string/lbl_email"
            android:inputType="text">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                style="@style/textInput"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Password"
            style="@style/cornertextInput"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="10dp"
            android:contentDescription="Campo de texto contraseña"
            android:ems="10"
            android:hint="@string/lbl_contrasena"
            android:inputType="textPassword"
            app:endIconMode="password_toggle"
            >

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="textPassword"
                style="@style/textInput" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:contentDescription="Boton iniciar sesion"
            android:elevation="0dp"
            android:fontFamily="@font/poppins_semibold"
            android:maxWidth="10dp"
            android:text="@string/lbl_iniciarSesion"
            android:textColor="@color/darkGreen"
            android:textSize="@dimen/button" />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:src="@drawable/svg_separador" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/Signin"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:contentDescription="Boton iniciar sesion"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/sesion_google"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/button"
            app:icon="@drawable/svg_google_icon"
            app:iconGravity="textStart"
            app:iconPadding="15dp"
            app:iconSize="25dp"
            app:iconTint="@null" />

        <TextView
            android:id="@+id/btn_registrar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="50dp"
            android:contentDescription="Boton registrarse"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:text="@string/lbl_noCuenta"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/body" />

      <!--  <TextView
            android:id="@+id/btn_registrar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp"
            android:contentDescription="Boton registrarse"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:paddingEnd="5dp"
            android:text="@string/lbl_noCuenta"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/body"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />-->

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>