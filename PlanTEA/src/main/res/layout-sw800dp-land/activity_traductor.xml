<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?customBgColor"
    tools:context=".presentacion.actividades.TraductorActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob_v2" />

    <ImageView
        android:id="@+id/imageView8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="80dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_blob"
        />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginStart="80dp"
        app:layout_constraintWidth_percent="0.85">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/subir"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="20dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/subir_documento"
            android:textColor="?colorOnSurface"
            app:icon="@drawable/svg_upload"
            app:iconTint="?colorOnSurface"
            app:iconPadding="5dp"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"
            android:textSize="@dimen/button" />

        <LinearLayout
            android:id="@+id/linearLayout12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_calendario"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textoTraducir"
                style="@style/backgroundTraduccion"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:layout_weight="1"
                android:hint="@string/str_escribe_frase"
                android:inputType="text"
                app:hintTextColor="?colorBG1">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_margin="5dp"
                    style="@style/textInput" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/traducirButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/str_traducir"
                android:textColor="@color/darkGreen"
                android:textSize="@dimen/button" />
        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_calendario">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_plan"
                android:layout_width="match_parent"
                android:layout_height="175dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:contentDescription="Lista con la planificación actual"
                android:scrollbars="horizontal"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.0" />

            <com.google.android.material.divider.MaterialDivider
                android:id="@+id/divider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="20dp"
                app:dividerColor="?color"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/recycler_plan" />


            <!--  <Button
                  android:id="@+id/escucharButtonPalabra"
                  style="@style/Widget.Material3.Button.IconButton.Outlined"
                  android:layout_width="270dp"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="10dp"
                  android:layout_marginEnd="20dp"
                  android:layout_marginBottom="10dp"
                  android:fontFamily="@font/poppins_semibold"
                  android:text="@string/str_escuchar"
                  android:textColor="?colorOnSurface"
                  android:textSize="14sp"
                  app:cornerRadius="25dp"
                  app:icon="@drawable/svg_sound"
                  app:iconSize="25dp"
                  app:iconTint="?colorOnSurface"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintTop_toBottomOf="@+id/recycler_plan"
                  app:layout_constraintVertical_bias="0.0" />

              <Button
                  android:id="@+id/escucharButtonFrase"
                  style="@style/Widget.Material3.Button.IconButton.Outlined"
                  android:layout_width="200dp"
                  android:layout_height="wrap_content"
                  android:layout_marginTop="10dp"
                  android:layout_marginEnd="300dp"
                  android:layout_marginBottom="10dp"
                  android:fontFamily="@font/poppins_semibold"
                  android:text="@string/str_escucharFrase"
                  android:textColor="?colorOnSurface"
                  android:textSize="14sp"
                  app:cornerRadius="25dp"
                  app:icon="@drawable/svg_sound"
                  app:iconSize="25dp"
                  app:iconTint="?colorOnSurface"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintEnd_toEndOf="parent"
                  app:layout_constraintTop_toBottomOf="@+id/recycler_plan"
                  app:layout_constraintVertical_bias="0.0" />-->

              <Button
                  android:id="@+id/guardarButton"
                  style="@style/Widget.Material3.Button.TonalButton"
                  android:layout_width="220dp"
                  android:layout_height="wrap_content"
                  android:layout_marginStart="20dp"
                  android:layout_marginTop="10dp"
                  android:layout_marginBottom="10dp"
                  android:fontFamily="@font/poppins_semibold"
                  android:text="@string/str_guardar_como"
                  android:textAllCaps="false"
                  android:textColor="?colorOnSurface"
                  android:textSize="14sp"
                  android:visibility="invisible"
                  app:cornerRadius="25dp"
                  app:iconGravity="textEnd"
                  app:icon="@drawable/svg_chevron_bottom"
                  app:iconSize="25dp"
                  app:iconTint="?colorOnSurface"
                  app:layout_constraintBottom_toBottomOf="parent"
                  app:layout_constraintStart_toStartOf="parent"
                  app:layout_constraintTop_toBottomOf="@+id/recycler_plan"
                  app:layout_constraintVertical_bias="0.0" />

          </androidx.constraintlayout.widget.ConstraintLayout>

      </LinearLayout>


      <androidx.fragment.app.FragmentContainerView
          android:id="@+id/fragmentContainerViewSide"
          android:name="com.example.plantea.presentacion.fragmentos.NavigationSideFragment"
          android:layout_width="wrap_content"
          android:layout_height="match_parent"
          android:elevation="7dp"
          app:shapeAppearance="@style/cornersNavigation"
          android:background="?colorBG1"

          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintBottom_toBottomOf="parent"
          app:layout_constraintTop_toTopOf="parent"/>

      <LinearLayout
          android:id="@+id/linearLayout15"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:layout_marginStart="100dp"
          android:layout_marginTop="20dp"
          android:gravity="center"
          android:orientation="horizontal"
          app:layout_constraintStart_toStartOf="parent"
          app:layout_constraintTop_toTopOf="parent">

          <Button
              android:id="@+id/atras"
              style="@style/Widget.Material3.Button.IconButton"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              app:icon="@drawable/svg_chevron_left"
              app:iconSize="35dp" />


          <TextView
              android:id="@+id/title"
              android:layout_width="wrap_content"
              android:layout_height="wrap_content"
              android:layout_marginStart="5dp"
              android:fontFamily="@font/poppins_semibold"
              android:text="@string/pantalla_traductor"
              android:textSize="@dimen/displaySmall" />

      </LinearLayout>



  </androidx.constraintlayout.widget.ConstraintLayout>