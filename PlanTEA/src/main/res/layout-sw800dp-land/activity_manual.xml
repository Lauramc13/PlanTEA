<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerView"
        android:name="com.example.plantea.presentacion.fragmentos.NavigationTopFragment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fragmentContainerView"
        app:srcCompat="@drawable/blob_v2"
        app:tint="?subColorBackground" />

    <ImageView
        android:id="@+id/imageView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_blob" />


    <TextView
        android:id="@+id/subtitulo_manual"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.9"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"
        android:text="@string/subtitulo_manual"
        android:fontFamily="@font/poppins_regular"
        android:textColor="?colorOnSurface"
        android:justificationMode="inter_word"
        android:layout_marginTop="40dp"
        app:layout_constraintBottom_toTopOf="@+id/subtitulo_manual2"
        app:layout_constraintStart_toStartOf="@+id/linearLayout15"
        app:layout_constraintTop_toBottomOf="@+id/fragmentContainerView"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/subtitulo_manual2"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.9"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/subtitulo_manual2"
        android:fontFamily="@font/poppins_regular"
        android:textColor="?colorOnSurface"
        android:justificationMode="inter_word"
        app:layout_constraintTop_toBottomOf="@+id/subtitulo_manual"
        app:layout_constraintStart_toStartOf="@+id/linearLayout15"
        android:textSize="16sp"/>

    <LinearLayout
        android:id="@+id/linearLayout15"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/subtitulo_manual2"
        android:layout_marginBottom="40dp"
        android:layout_marginTop="40dp"
        app:layout_constraintWidth_max="1200dp"
        app:layout_constraintWidth_percent="0.9">

        <LinearLayout
            android:layout_width="600dp"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ScrollView
                android:id="@+id/scrollView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingEnd="10dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_evento"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:clickable="true"
                        app:cardBackgroundColor="?configuracionCardBg"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?color"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textColor="?colorOnSurface"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/titulo_crearEvento"
                                android:textSize="@dimen/modalText" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <ImageView
                                android:id="@+id/icon_evento"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/svg_chevron_right"
                                app:tint="?colorOnSurface" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/text_evento"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="70dp"
                            android:clickable="false"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:scrollbars="none" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_evento_edit"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="15dp"
                        android:background="@drawable/bg_close_button"
                        android:clickable="true"
                        app:cardBackgroundColor="?configuracionCardBg"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?color"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textColor="?colorOnSurface"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/titulo_editarEvento"
                                android:textSize="@dimen/modalText" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <ImageView
                                android:id="@+id/icon_evento_edit"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/svg_chevron_right"
                                app:tint="?colorOnSurface" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/text_evento_edit"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="70dp"
                            android:clickable="false"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:scrollbars="none" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_planificacion"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="15dp"
                        android:background="@drawable/bg_close_button"
                        android:clickable="true"
                        app:cardBackgroundColor="?configuracionCardBg"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?color"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textColor="?colorOnSurface"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/titulo_crearPlanificacion"
                                android:textSize="@dimen/modalText" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <ImageView
                                android:id="@+id/icon_planificacion"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/svg_chevron_right"
                                app:tint="?colorOnSurface" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/text_planificacion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="70dp"
                            android:clickable="false"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:scrollbars="none" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_calendarioSemanal"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="15dp"
                        android:background="@drawable/bg_close_button"
                        android:clickable="true"
                        app:cardBackgroundColor="?configuracionCardBg"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?color"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textColor="?colorOnSurface"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/titulo_calendarioSemanal"
                                android:textSize="@dimen/modalText" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <ImageView
                                android:id="@+id/icon_calendarioSemanal"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/svg_chevron_right"
                                app:tint="?colorOnSurface" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/text_calendarioSemanal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="70dp"
                            android:clickable="false"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:scrollbars="none" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_calendarioMensual"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="15dp"
                        android:background="@drawable/bg_close_button"
                        android:clickable="true"
                        app:cardBackgroundColor="?configuracionCardBg"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?color"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textColor="?colorOnSurface"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/titulo_calendarioMensual"
                                android:textSize="@dimen/modalText" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <ImageView
                                android:id="@+id/icon_calendarioMensual"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/svg_chevron_right"
                                app:tint="?colorOnSurface" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/text_calendarioMensual"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="70dp"
                            android:clickable="false"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:scrollbars="none" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_actividades"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="15dp"
                        android:background="@drawable/bg_close_button"
                        android:clickable="true"
                        app:cardBackgroundColor="?configuracionCardBg"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?color"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textColor="?colorOnSurface"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/titulo_actividades"
                                android:textSize="@dimen/modalText" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <ImageView
                                android:id="@+id/icon_actividades"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/svg_chevron_right"
                                app:tint="?colorOnSurface" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/text_actividades"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="70dp"
                            android:clickable="false"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:scrollbars="none" />

                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_traductor"
                        android:layout_width="match_parent"
                        android:layout_height="70dp"
                        android:layout_marginTop="15dp"
                        android:background="@drawable/bg_close_button"
                        android:clickable="true"
                        app:cardBackgroundColor="?configuracionCardBg"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:strokeColor="?color"
                        app:strokeWidth="1.5dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="70dp"
                            android:orientation="horizontal"
                            android:padding="20dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:textColor="?colorOnSurface"
                                android:fontFamily="@font/poppins_regular"
                                android:text="@string/titulo_traductor"
                                android:textSize="@dimen/modalText" />

                            <View
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1" />

                            <ImageView
                                android:id="@+id/icon_traductor"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:src="@drawable/svg_chevron_right"
                                app:tint="?colorOnSurface" />

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/text_traductor"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="70dp"
                            android:clickable="false"
                            android:paddingStart="20dp"
                            android:paddingEnd="20dp"
                            android:scrollbars="none" />

                    </com.google.android.material.card.MaterialCardView>

                    <Button
                        android:id="@+id/btn_tutorial"
                        style="@style/Widget.Material3.Button.TonalButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="@font/poppins_medium"
                        android:text="@string/repetir_tutorial"
                        android:textAllCaps="false"
                        android:textSize="14sp" />

                </LinearLayout>
            </ScrollView>
        </LinearLayout>


        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="50dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="?color"
            app:strokeWidth="1.5dp">

            <pl.droidsonroids.gif.GifImageView
                android:id="@+id/fragment_imagen"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:scaleType="fitXY"
                android:padding="20dp"
                android:layout_gravity="center"
                android:src="@drawable/svg_manual" />
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>