


<selector xmlns:android="http://schemas.android.com/apk/res/android">
<item android:state_enabled="false">
    <layer-list>
        <item>
            <shape android:shape="rectangle">
                <solid android:color="@color/md_theme_dark_surfaceVariant3"/>
            </shape>
        </item>
        <item android:bottom="5dp" android:top="0dp" android:start="0dp" android:end="0dp">
            <shape android:shape="rectangle">
                <solid android:color="@color/md_theme_dark_surfaceVariant" />
            </shape>
        </item>

    </layer-list>
</item>
<item android:state_enabled="true">
    <layer-list>
        <item>
            <shape android:shape="rectangle">
                <solid android:color="@color/md_theme_dark_background2"/>
            </shape>
        </item>
        <item android:bottom="5dp">
            <shape android:shape="rectangle">
                <solid android:color="@color/md_theme_dark_surfaceVariant" />
            </shape>
        </item>
    </layer-list>
</item>
</selector>
