<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="15dp"
    android:background="@drawable/bg_popup">

    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_close_button"
        android:src="@drawable/svg_close"
        android:padding="12dp"
        android:alpha="0.9"
        android:layout_gravity="end"/>

    <TextView
        android:id="@+id/lbl_Logout3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="5dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:fontFamily="@font/poppins_semibold"
        android:gravity="center"
        android:text="@string/colores_fondo_dia"
        android:textColor="?colorOnSurface"
        android:textSize="@dimen/modalText" />

    <LinearLayout
        android:id="@+id/layout_colors_header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="15dp">


        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabRED_H"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorRed"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabORANGE_H"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorOrange"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabYELLOW_H"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorYellow"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabGREEN_H"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorGreen"
            android:layout_margin="2dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabBLUE_H"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorBlue"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabPINK_H"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            app:elevation="0dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorPink"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabPURPLE_H"
            app:elevation="0dp"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorPurple"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabDEFAULT_H"
            app:elevation="0dp"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?whitish"
            app:strokeWidth="1dp"
            app:strokeColor="?color"
            android:layout_margin="2dp" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_header"
        android:layout_width="100dp"
        android:layout_height="40dp"
        android:layout_marginTop="10dp"
        android:layout_gravity="center"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:cardBackgroundColor="?whitish"
        app:strokeColor="@color/md_theme_light_surfaceVariant"
        app:cardCornerRadius="0dp"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_body"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="10dp"
        android:layout_gravity="center"
        android:layout_marginTop="-3dp"
        app:cardElevation="0dp"
        app:strokeWidth="1.5dp"
        app:cardBackgroundColor="?whitish"
        app:strokeColor="@color/md_theme_light_surfaceVariant"
        app:cardCornerRadius="0dp"/>

    <LinearLayout
        android:id="@+id/layout_colors_body"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabRED"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorRed"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabORANGE"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorOrange"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabYELLOW"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorYellow"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabGREEN"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorGreen"
            android:layout_margin="2dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabBLUE"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorBlue"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabPINK"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorPink"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabPURPLE"
            style="@style/buttonsColorsCategorias"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?colorPurple"
            android:layout_margin="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fabDEFAULT"
            app:elevation="0dp"
            android:layout_width="40dp"
            app:cornerRadius="30dp"
            android:layout_height="wrap_content"
            android:backgroundTint="?whitish"
            app:strokeWidth="1dp"
            app:strokeColor="?color"
            android:layout_margin="2dp" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_gravity="center">


        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:layout_marginBottom="10dp"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancelar"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="20dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/lbl_cancelar"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/button"
                app:cornerRadius="25dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_guardar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/btn_Guardar"
                android:textAllCaps="false"
                android:textColor="@color/darkGreen"
                android:textSize="@dimen/button"
                app:cornerRadius="25dp" />


        </LinearLayout>
    </LinearLayout>


</LinearLayout>