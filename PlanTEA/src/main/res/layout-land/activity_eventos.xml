<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?customBgColor"
    android:fitsSystemWindows="true"
    tools:context=".presentacion.actividades.EventosActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob_v2" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/question"
        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:iconSize="32dp"
        android:visibility="gone"
        app:icon="@drawable/svg_question" />

    <ImageView
        android:id="@+id/imageDecoration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_blob" />

    <LinearLayout
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.8"
        android:layout_height="0dp"
        android:gravity="center"
        android:layout_marginStart="70dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_cards_configuracion">



            <LinearLayout
                android:id="@+id/layout_fecha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="10dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    android:id="@+id/lbl_dia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:contentDescription="Mes"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Viernes, 9 de septiembre"
                    android:textColor="?colorTertiary"
                    android:textFontWeight="900"
                    android:textSize="@dimen/titleSmall" />

                <TextView
                    android:id="@+id/guion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:contentDescription="Mes"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="-"
                    android:textColor="?colorTertiary"
                    android:textFontWeight="900"
                    android:textSize="@dimen/titleSmall"
                    app:layout_constraintStart_toEndOf="@+id/lbl_dia"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/lbl_hora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginStart="10dp"
                    android:contentDescription="Mes"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="00:00"
                    android:textColor="?colorTertiary"
                    android:textFontWeight="900"
                    android:textSize="@dimen/titleSmall"
                    app:layout_constraintStart_toEndOf="@+id/guion"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="0dp"/>

                <Button
                    android:id="@+id/CalendarDate"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    app:cornerRadius="25dp"
                    app:icon="@drawable/svg_calendar"
                    app:iconSize="20dp"
                    app:iconTint="?colorOnSurface"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    app:icon="@drawable/svg_info_simple"
                    app:iconGravity="textStart"
                    app:iconSize="20dp"
                    app:iconTint="?colorOnSurface"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/linearLayout4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:layout_marginBottom="10dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <Button
                    android:id="@+id/icon_deshacerTodas"
                    style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                    android:layout_width="60dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Botón reproducir lista"
                    android:elevation="0dp"
                    android:enabled="false"
                    android:textColor="@color/darkGreen"
                    android:textSize="20sp"
                    android:theme="@style/botonesSecundarios"
                    app:cornerRadius="25dp"
                    app:icon="@drawable/svg_rewind"
                    app:iconGravity="textEnd"
                    app:iconSize="20dp"
                    app:iconTint="@color/darkGreen" />

                <Button
                    android:id="@+id/icon_deshacer"
                    style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Botón reproducir lista"
                    android:elevation="0dp"
                    android:enabled="false"
                    android:textColor="@color/darkGreen"
                    android:textSize="20sp"
                    android:theme="@style/botonesSecundarios"
                    app:cornerRadius="25dp"
                    app:icon="@drawable/svg_play_goback"
                    app:iconGravity="textEnd"
                    app:iconSize="20dp"
                    app:iconTint="@color/darkGreen" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/icon_reproducir"
                    style="@style/Widget.Material3.Button.IconButton.Filled"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:contentDescription="Botón reproducir lista"
                    android:elevation="0dp"
                    android:enabled="true"
                    android:textColor="@color/darkGreen"
                    android:textSize="20sp"
                    app:cornerRadius="100dp"
                    app:icon="@drawable/svg_play"
                    app:iconGravity="textEnd"
                    app:iconSize="25dp"
                    app:iconTint="@color/darkGreen" />

                <Button
                    android:id="@+id/icon_marcar"
                    style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:contentDescription="Botón reproducir lista"
                    android:textColor="@color/darkGreen"
                    android:textSize="20sp"
                    android:theme="@style/botonesSecundarios"
                    app:cornerRadius="25dp"
                    app:elevation="0dp"
                    app:icon="@drawable/svg_play_gofoward"
                    app:iconSize="20dp"
                    app:iconTint="@color/darkGreen" />

                <Button
                    android:id="@+id/icon_marcarTodas"
                    style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                    android:layout_width="60dp"
                    android:layout_height="48dp"
                    android:layout_marginStart="10dp"
                    android:contentDescription="Botón reproducir lista"
                    android:elevation="0dp"
                    android:textColor="@color/darkGreen"
                    android:textSize="20sp"
                    android:theme="@style/botonesSecundarios"
                    app:cornerRadius="25dp"
                    app:icon="@drawable/svg_foward"
                    app:iconGravity="textEnd"
                    app:iconSize="20dp"
                    app:iconTint="@color/darkGreen" />
            </LinearLayout>

            <TextView
                android:id="@+id/lbl_titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:fontFamily="@font/poppins_bold"
                android:text="@string/titulo"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/layout_fecha" />

            <LinearLayout
                android:id="@+id/layout_no_eventos"
                android:layout_width="0dp"
                app:layout_constraintWidth_percent="0.7"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toBottomOf="@id/constraintLayout"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@id/constraintLayout"
                android:orientation="vertical"
                android:paddingTop="60dp"
                android:paddingBottom="60dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="30dp"
                    android:layout_marginStart="80dp"
                    android:layout_marginEnd="80dp"
                    android:src="@drawable/svg_ticket"
                    android:layout_marginBottom="20dp"
                    android:scaleType="fitXY"
                    android:layout_gravity="center"
                    android:adjustViewBounds="true" />

                <TextView
                    android:id="@+id/mensajeEventos"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center|top"
                    android:layout_gravity="center"
                    android:fontFamily="@font/poppins_regular"
                    android:text="@string/no_eventos_disponibles"
                    android:textColor="?colorOnSurface"
                    android:textSize="@dimen/modalText" />

            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_plan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="5dp"
                android:clipToPadding="true"
                android:background="@drawable/fragment_personalizado"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                app:layout_constraintBottom_toTopOf="@+id/linearLayout4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lbl_titulo"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerViewSide"
        android:name="com.example.plantea.presentacion.fragmentos.NavigationSideFragment"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:elevation="7dp"
        app:shapeAppearance="@style/cornersNavigation"
        android:background="?colorBG1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>