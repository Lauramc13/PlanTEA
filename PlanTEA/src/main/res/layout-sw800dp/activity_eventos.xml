<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?customBgColor"
    tools:context=".presentacion.actividades.EventosActivity">

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/blob_v2"
        />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/question"
        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:iconSize="32dp"
        android:visibility="gone"
        app:icon="@drawable/svg_question" />

    <ImageView
        android:id="@+id/imageDecoration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/svg_blob" />

    <LinearLayout
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.9"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@+id/fragmentContainerViewBottom"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/fragmentContainerView">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="match_parent"
        android:layout_height="550dp"
        android:background="@drawable/bg_cards_configuracion">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/borrar_importantes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/borrar_imprevistos"
            android:layout_margin="10dp"
            android:fontFamily="@font/poppins_medium"
            android:textColor="?colorRedImportante"
            android:textSize="@dimen/button"
            android:visibility="gone"
            android:backgroundTint="?colorTertiaryContainer"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <LinearLayout
            android:id="@+id/layout_fecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:contentDescription="Mes y flechas de navegación atras/delante"
            android:orientation="horizontal"
            app:cornerRadius="25dp"
            android:layout_marginTop="20dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/lbl_dia"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginRight="10dp"
                android:contentDescription="Mes"
                android:fontFamily="@font/poppins_semibold"
                android:text="Viernes, 9 de septiembre"
                android:textColor="?colorTertiary"
                android:textFontWeight="900"
                android:textSize="20sp" />

            <Button
                android:id="@+id/CalendarDate"
                style="@style/Widget.Material3.Button.IconButton.Outlined"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="Botón calendario"
                android:gravity="center"
                app:cornerRadius="25dp"
                app:icon="@drawable/svg_calendar"
                app:iconSize="25dp"
                app:iconTint="?colorOnSurface">

            </Button>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/linearLayout4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:layout_marginBottom="30dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            >

            <Button
                android:id="@+id/icon_deshacerTodas"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"

                android:layout_width="90dp"
                android:layout_height="48dp"
                android:layout_marginEnd="15dp"
                android:contentDescription="Botón reproducir lista"
                android:elevation="0dp"
                android:enabled="false"
                android:textColor="@color/darkGreen"
                android:textSize="20sp"
                android:theme="@style/botonesSecundarios"
                app:cornerRadius="25dp"
                app:icon="@drawable/svg_rewind"
                app:iconGravity="textEnd"
                app:iconSize="28dp"
                app:iconTint="@color/darkGreen" />

            <Button
                android:id="@+id/icon_deshacer"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginEnd="15dp"
                android:contentDescription="Botón reproducir lista"
                android:elevation="0dp"
                android:enabled="false"
                android:textColor="@color/darkGreen"
                android:textSize="20sp"
                android:theme="@style/botonesSecundarios"
                app:cornerRadius="25dp"
                app:icon="@drawable/svg_play_goback"
                app:iconGravity="textEnd"
                app:iconSize="25dp"
                app:iconTint="@color/darkGreen" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/icon_reproducir"
                style="@style/Widget.Material3.Button.IconButton.Filled"
                android:layout_width="67dp"
                android:layout_height="67dp"
                android:contentDescription="Botón reproducir lista"
                android:elevation="0dp"
                android:enabled="true"
                android:textColor="@color/darkGreen"
                android:textSize="20sp"
                app:cornerRadius="100dp"
                app:icon="@drawable/svg_play"
                app:iconGravity="textEnd"
                app:iconSize="35dp"
                app:iconTint="@color/darkGreen" />


            <Button
                android:id="@+id/icon_marcar"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="15dp"
                android:contentDescription="Botón reproducir lista"
                android:textColor="@color/darkGreen"
                android:textSize="20sp"
                android:theme="@style/botonesSecundarios"
                app:cornerRadius="25dp"
                app:elevation="0dp"
                app:icon="@drawable/svg_play_gofoward"
                app:iconSize="25dp"
                app:iconTint="@color/darkGreen" />

            <Button
                android:id="@+id/icon_marcarTodas"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="90dp"
                android:layout_height="48dp"
                android:layout_marginStart="15dp"
                android:contentDescription="Botón reproducir lista"
                android:elevation="0dp"
                android:textColor="@color/darkGreen"
                android:textSize="20sp"
                android:theme="@style/botonesSecundarios"
                app:cornerRadius="25dp"
                app:icon="@drawable/svg_foward"
                app:iconGravity="textEnd"
                app:iconSize="28dp"
                app:iconTint="@color/darkGreen" />
        </LinearLayout>

