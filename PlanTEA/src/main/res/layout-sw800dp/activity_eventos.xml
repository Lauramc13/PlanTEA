        <TextView
            android:id="@+id/lbl_titulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="10dp"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/titulo"
            android:textColor="?colorOnSurface"
            android:textSize="30sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layout_fecha" />

        <LinearLayout
            android:id="@+id/layout_no_eventos"
            android:layout_width="wrap_content"
            app:layout_constraintHeight_percent="0.25"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="@id/constraintLayout"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/constraintLayout"
            android:orientation="vertical"
            android:visibility="gone">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="10dp"
                android:src="@drawable/svg_ticket"
                android:scaleType="fitXY"
                android:layout_gravity="center"
                android:adjustViewBounds="true" />

            <TextView
                android:id="@+id/mensajeEventos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center|top"
                android:layout_gravity="center"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/lbl_mensajeNinio"
                android:textColor="?colorOnSurface"
                android:textSize="@dimen/title" />

        </LinearLayout>


        <TextView
            android:id="@+id/lbl_importante"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/importante"
            android:textColor="@color/red"
            android:visibility="gone"
            android:fontFamily="@font/poppins_semibold"
            android:textSize="20sp"
            android:layout_marginBottom="-10dp"
            app:layout_constraintBottom_toTopOf="@+id/recycler_plan"
            tools:ignore="MissingConstraints" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_plan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="true"
                android:padding="10dp"
                android:layout_margin="20dp"
                android:contentDescription="Lista con la planificación actual"
                android:scrollbars="horizontal"
                android:background="@drawable/fragment_personalizado"
                app:layout_constraintBottom_toTopOf="@+id/linearLayout4"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lbl_titulo"/>



    </androidx.constraintlayout.widget.ConstraintLayout>


