<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:id="@+id/fragment_nuevo_picto_nombre"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <FrameLayout
        android:id="@+id/frameImage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_textinputedit"
        app:layout_constraintBottom_toBottomOf="@+id/colors2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.155"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/txt_Titulo">

        <ImageView
            android:id="@+id/img_NuevoPicto"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_margin="5dp"
            app:shapeAppearance="@style/cornerRadius" />
    </FrameLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Titulo"
            style="@style/cornertextInput"
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="20dp"
            android:contentDescription="Campo de texto nombre de usuario"
            android:ems="10"
            android:layout_marginTop="20dp"
            android:hint="@string/lbl_tulo"
            android:inputType="text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/frameImage"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                style="@style/textInput"/>
        </com.google.android.material.textfield.TextInputLayout>


    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:fontFamily="@font/poppins_regular"
        android:text="@string/color"
        android:textColor="?colorOnSurface"
        android:textSize="@dimen/modalText"
        app:layout_constraintStart_toStartOf="@+id/txt_Titulo"
        app:layout_constraintTop_toBottomOf="@+id/txt_Titulo" />

    <LinearLayout
        android:id="@+id/colors"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="@+id/txt_Titulo"
        app:layout_constraintStart_toStartOf="@+id/txt_Titulo"
        app:layout_constraintTop_toBottomOf="@+id/textView3">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab1"
            android:layout_width="70dp"
            android:layout_height="60dp"
            app:strokeWidth="0dp"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconTint="@color/md_theme_light_shadow"
            app:backgroundTint="?colorPurple" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab2"
            android:layout_width="70dp"
            android:layout_height="60dp"
            app:strokeWidth="0dp"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconTint="@color/md_theme_light_shadow"
            app:backgroundTint="?colorPink" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab3"
            android:layout_width="70dp"
            android:layout_height="60dp"
            app:strokeWidth="0dp"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconTint="@color/md_theme_light_shadow"
            app:backgroundTint="?colorGreen" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/colors2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintStart_toStartOf="@+id/colors"
        app:layout_constraintTop_toBottomOf="@+id/colors">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab4"
            android:layout_width="70dp"
            android:layout_height="60dp"
            app:strokeWidth="0dp"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconTint="@color/md_theme_light_shadow"
            app:backgroundTint="?colorYellow" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab5"
            android:layout_width="70dp"
            android:layout_height="60dp"
            app:strokeWidth="0dp"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconTint="@color/md_theme_light_shadow"
            app:backgroundTint="?colorBlue" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab6"
            android:layout_width="70dp"
            android:layout_height="60dp"
            app:strokeWidth="0dp"
            app:cornerRadius="15dp"
            app:iconGravity="textStart"
            style="@style/Widget.Material3.Button.IconButton"
            app:iconTint="?colorOnSurface"
            app:backgroundTint="?color" />
    </LinearLayout>


    <Button
        android:id="@+id/btn_GuardarPicto"
        style="@style/Widget.Material3.Button"
        android:layout_width="250dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/poppins_semibold"
        android:text="@string/crear_categoria"
        android:textColor="@color/darkGreen"
        android:textSize="@dimen/button"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/colors2" />
    </androidx.constraintlayout.widget.ConstraintLayout>
