<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:layout_margin="10dp">

    <androidx.cardview.widget.CardView
        android:id="@+id/categoria"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        app:cardCornerRadius="15dp"
        app:cardElevation="0dp"
        android:background="@drawable/card_dotted_categorias"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/img_categoria"
                android:layout_width="95dp"
                android:layout_height="87dp"
                android:layout_gravity="center"
                android:padding="2dp"
                app:srcCompat="@drawable/svg_add_20"/>

            <TextView
                android:id="@+id/lbl_titulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/lbl_IrMedico"
                android:textAllCaps="false"
                android:textAlignment="center"
                android:gravity="center"
                android:textColor="?colorOnSurface"
                android:textSize="16sp"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_borrarPicto"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:elevation="4dp"
            android:padding="5dp"
            android:layout_margin="3dp"
            app:tint="?colorOnSurfaceVariant"
            android:visibility="visible"
            app:srcCompat="@drawable/svg_trash"/>

    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>