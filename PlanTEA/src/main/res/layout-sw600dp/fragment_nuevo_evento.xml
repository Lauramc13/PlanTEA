<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/btn_desplegar"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/img_cancelarEvento"
        android:layout_width="48dp"
        android:layout_height="40dp"
        android:layout_gravity="end"
        android:layout_margin="15dp"
        android:padding="12dp"
        android:background="@drawable/bg_close_button"
        android:contentDescription="Cerrar configuración nuevo evento"
        app:srcCompat="@drawable/svg_close" />

    <TextView
        android:id="@+id/lbl_nuevoEvento"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginBottom="10dp"
        android:text="@string/lbl_nuevoEvento"
        android:fontFamily="@font/poppins_semibold"
        android:textAlignment="center"
        android:layout_marginTop="30dp"
        android:textColor="?colorOnSurface"
        android:textSize="@dimen/title" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        android:layout_marginTop="80dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="25dp"
            android:paddingEnd="25dp"
            android:orientation="vertical">


            <!--   <EditText
                   android:id="@+id/txt_tituloEvento"
                   android:hint="Titulo"
                   android:theme="@style/AppTheme.CursorBubble"
                   android:layout_width="match_parent"
                   android:layout_height="wrap_content"
                   android:fontFamily="@font/poppins_regular"
                   android:layout_gravity="center_vertical|end"
                   android:textColor="?colorOnSurface"
                   android:inputType="textCapSentences"
                   style="@style/cornerRadiusEvento"
                   android:layout_marginBottom="10dp"
                   android:textSize="18sp" /> -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:orientation="horizontal"
                android:padding="3dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/svg_calendar"/>

                <TextView
                    android:id="@+id/textView11"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fecha"
                    android:layout_marginStart="10dp"
                    android:fontFamily="@font/poppins_regular"
                    android:textColor="?colorOnSurface"
                    android:textSize="16sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/lbl_fechaEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="29 noviembre 2021"
                android:fontFamily="@font/poppins_regular"
                android:textAlignment="center"
                android:padding="10dp"
                android:background="@drawable/bg_text_form_evento"
                android:textColor="?colorOnSurface"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:layout_marginTop="15dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/svg_clock"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Todo el dia"
                    android:layout_marginStart="10dp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="16sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_allDay"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:theme="@style/Switches"/>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/layout_hora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_horaEvento"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="@string/hora_inicio"
                    android:gravity="center"
                    android:padding="10dp"
                    android:textColorHint="?colorOnSurface"
                    android:background="@drawable/bg_text_form_evento"
                    android:contentDescription="Boton seleccionar hora"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:text="-"
                    android:contentDescription="Boton seleccionar hora"
                    android:textSize="16sp"
                    android:layout_marginStart="10dp"
                    android:layout_marginEnd="10dp"
                    android:fontFamily="@font/poppins_regular"/>

                <TextView
                    android:id="@+id/btn_horaFinEvento"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:hint="@string/hora_fin"
                    android:gravity="center"
                    android:padding="10dp"
                    android:textColorHint="?colorOnSurface"
                    android:background="@drawable/bg_text_form_evento"
                    android:contentDescription="Boton seleccionar hora"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_regular"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:padding="3dp"
                android:layout_marginTop="15dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/svg_map"/>

                <TextView
                    android:id="@+id/lbl_localizacion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/localizacion"
                    android:layout_marginStart="10dp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="16sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="0.3" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/localizacionText"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_texto_login"
                android:inputType="text"
                android:maxLength="150"
                android:textColor="?colorOnSurface"
                android:textColorHint="?colorOnSurface"
                app:shapeAppearance="@style/cornerRadiusLogin">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textMultiLine"
                    android:background="@drawable/bg_text_form_evento"
                    android:textColor="?colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="3dp"
                android:layout_marginTop="15dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/svg_bell"/>

                <TextView
                    android:id="@+id/lbl_recordatorio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recordatorio"
                    android:layout_marginStart="10dp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="16sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_recordatorio"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:theme="@style/Switches"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:padding="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/svg_eye_on"/>

                <TextView
                    android:id="@+id/lbl_hacer_visible"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hacer_visible_5_min_antes"
                    android:layout_marginStart="10dp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="16sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switch_hacer_visible"
                    android:layout_width="wrap_content"
                    android:layout_height="35dp"
                    android:theme="@style/Switches"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="5dp"
                android:padding="3dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="25dp"
                    android:layout_height="25dp"
                    android:src="@drawable/svg_notes"/>

                <TextView
                    android:id="@+id/lbl_notas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/notas"
                    android:layout_marginStart="10dp"
                    android:textColor="?colorOnSurface"
                    android:fontFamily="@font/poppins_regular"
                    android:textSize="16sp" />

            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/notasText"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/fondo_texto_login"
                android:ems="10"
                android:inputType="text"
                android:textColor="?colorOnSurface"
                android:textColorHint="?colorOnSurface"
                app:shapeAppearance="@style/cornerRadiusLogin">

                <com.google.android.material.textfield.TextInputEditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="100dp"
                    android:inputType="textMultiLine"
                    android:gravity="top"
                    android:maxLength="400"
                    android:background="@drawable/bg_text_form_evento"
                    android:textColor="?colorOnSurface" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:id="@+id/lbl_planificacionesDisponibles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/poppins_regular"
                android:text="@string/planificaciones_disponibles"
                android:textColor="?colorOnSurface"
                android:textSize="16sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/layout"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <TextView
                    android:id="@+id/lbl_mensajePlanes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="10dp"
                    android:layout_marginBottom="137dp"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:text="@string/lbl_mensaje"
                    android:textColor="?colorOnSurface"
                    android:textSize="16sp"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_planificaciones"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:nestedScrollingEnabled="false"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="0.0"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="1.0"/>



            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_margin="20dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_borrarEvento"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/lbl_eliminar"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/button"
            android:visibility="gone"
            app:cornerRadius="25dp"
            android:layout_marginEnd="10dp"
            app:iconPadding="10dp"
            app:icon="@drawable/svg_trash"
            app:iconGravity="textStart"
            app:iconTint="?colorOnSurface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardarEvento"
            style="@style/Widget.Material3.Button"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:enabled="false"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/btn_Guardar"
            android:textColor="@color/darkGreen"
            android:textSize="@dimen/button"
            app:cornerRadius="25dp"
            app:icon="@drawable/svg_save"
            app:iconGravity="textStart"
            app:iconPadding="10dp"
            app:iconSize="20dp"
            android:layout_gravity="center"
            app:iconTint="@color/darkGreen" />
    </LinearLayout>

</FrameLayout>