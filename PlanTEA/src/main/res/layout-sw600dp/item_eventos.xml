<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.google.android.material.button.MaterialButton
        android:id="@+id/icon_eye"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        app:iconSize="22dp"
        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
        app:icon="@drawable/svg_open"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:id="@+id/card_plan"
        android:layout_height="70dp"
        style="@style/items"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:strokeColor="?color"
        app:strokeWidth="1.5dp"
        app:cardCornerRadius="20dp"
        android:layout_marginBottom="10dp"
        android:layout_marginStart="60dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/lbl_Planificacion"
                        android:layout_width="match_parent"
                        android:layout_height="28dp"
                        android:maxLines="1"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="20dp"
                        android:autoSizeTextType="uniform"
                        android:autoSizeStepGranularity="1sp"
                        android:autoSizeMaxTextSize="17sp"
                        android:textSize="17sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:textColor="?colorOnSurface"
                        android:text="Ejemplo plan"/>

                    <TextView
                        android:id="@+id/lbl_Fecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/menuItems"
                        android:gravity="center"
                        android:visibility="visible"
                        android:textColor="?colorOnSurface"
                        android:fontFamily="@font/poppins_regular"
                        android:layout_marginStart="10dp"
                        android:text="1 de enero 2025"/>
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/icon_visibility"
                    android:layout_width="42dp"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_height="wrap_content"
                    app:iconSize="30dp"
                    app:iconTint="?colorOnSurface"
                    android:padding="0dp"
                    app:strokeWidth="0dp"
                    android:layout_gravity="center_vertical"
                    app:iconGravity="textStart"
                    app:icon="@drawable/svg_eye_on" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/icon_edit"
                    android:layout_width="42dp"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_height="wrap_content"
                    app:iconSize="25dp"
                    app:iconTint="?colorOnSurface"
                    android:padding="0dp"
                    app:strokeWidth="0dp"
                    app:iconGravity="textStart"
                    android:layout_gravity="center_vertical"
                    app:icon="@drawable/svg_edit_outline" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/icon_export"
                    android:layout_width="42dp"
                    style="@style/Widget.Material3.Button.IconButton.Outlined"
                    android:layout_height="wrap_content"
                    app:iconSize="25dp"
                    app:iconTint="?colorOnSurface"
                    android:padding="0dp"
                    app:strokeWidth="0dp"
                    app:iconGravity="textStart"
                    app:icon="@drawable/svg_export"
                    android:layout_gravity="center_vertical"
                    android:layout_marginEnd="10dp"/>


            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/items_planificacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_marginTop="-5dp"
                android:layout_marginEnd="15dp"
                android:layout_marginBottom="5dp"
                android:clickable="false"
                android:focusable="false"
                android:elevation="0dp"
                android:layout_gravity="center"
                android:visibility="visible"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>