<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?colorBG0"
    tools:context=".presentacion.actividades.PreLoginActivity">

    <ImageView
        android:id="@+id/imageView6"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        app:layout_constraintHeight_percent="0.65"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/background_login_svg" />

    <TextView
        android:id="@+id/textView6"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fontFamily="@font/tiltneon"
        android:gravity="center"
        android:layout_marginTop="30dp"
        android:text="@string/app_name"
        android:textColor="@color/darkGreen"
        app:autoSizeTextType="uniform"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.11"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.5" />

    <ImageView
        android:id="@+id/imageView7"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginBottom="16dp"
        android:adjustViewBounds="true"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout8"
        app:layout_constraintEnd_toEndOf="@+id/imageView6"
        app:layout_constraintHeight_percent="0.3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView6"
        app:srcCompat="@drawable/svg_problemsolving" />

    <LinearLayout
        android:id="@+id/linearLayout8"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/imageView7"
        app:layout_constraintWidth_max="350dp"
        app:layout_constraintWidth_percent="0.8">

        <TextView
            android:id="@+id/textView7"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginBottom="10dp"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:textSize="@dimen/title"
            android:text="@string/bienvenido_de_nuevo"
            android:textColor="?colorOnSurface"
            app:autoSizeTextType="uniform" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/cornertextInput"
            android:layout_marginTop="10dp"
            android:contentDescription="Campo de texto nombre de usuario"
            android:hint="@string/lbl_email"
            android:inputType="text">

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                style="@style/textInput"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/txt_Password"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            style="@style/cornertextInput"
            android:layout_marginTop="10dp"
          android:contentDescription="Campo de texto contraseña"
            android:fontFamily="@font/poppins_regular"
            android:hint="@string/lbl_contrasena"
            android:inputType="textPassword"
            app:endIconMode="password_toggle"
            >

            <com.google.android.material.textfield.TextInputEditText
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:inputType="textPassword"
                style="@style/textInput"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_login"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"
            android:contentDescription="Boton iniciar sesion"
            android:elevation="0dp"
            android:fontFamily="@font/poppins_semibold"
            android:maxWidth="10dp"
            android:text="@string/lbl_iniciarSesion"
            android:textColor="@color/darkGreen"
            android:textSize="@dimen/button" />

       <!--<TextView
            android:id="@+id/btn_olvidar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:text="@string/lbl_contraseniaOlvidada"
            android:textColor="?colorOnSurface" /> -->

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:src="@drawable/svg_separador" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/Signin"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:contentDescription="Boton iniciar sesion"
            android:fontFamily="@font/poppins_semibold"
            android:text="@string/sesion_google"
            android:textColor="?colorOnSurface"
            android:textSize="@dimen/button"
            app:icon="@drawable/svg_google_icon"
            app:iconGravity="textStart"
            app:iconPadding="15dp"
            app:iconSize="25dp"
            app:iconTint="@null" />

        <TextView
            android:id="@+id/btn_registrar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="30dp"
            android:contentDescription="Boton registrarse"
            android:fontFamily="@font/poppins_semibold"
            android:gravity="center"
            android:paddingEnd="5dp"
            android:text="@string/lbl_noCuenta"
            android:textColor="?colorOnSurface"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </LinearLayout>


    <FrameLayout
        android:id="@+id/frameLayout_idiomas"
        android:layout_width="55dp"
        android:layout_height="48dp"
        android:layout_marginEnd="25dp"
        android:layout_marginTop="40dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <Spinner
            android:id="@+id/spinner_idiomas"
            style="@style/dropdownMenuIdioma"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:backgroundTint="?colorOnSurfaceInverse"
            android:dropDownVerticalOffset="48dp"
            android:fontFamily="@font/poppins_regular"
            android:popupBackground="@drawable/custom_popup_background_idioma"
            android:popupElevation="1dp"
            android:spinnerMode="dropdown" />

        <ImageView
            android:id="@+id/image_idioma"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="start|bottom"
            android:layout_margin="5dp"
            android:background="?colorOnSurfaceInverse"
            android:contentDescription="@null"
            android:padding="5dp"
            android:src="@drawable/ic_es" />
    </FrameLayout>


</androidx.constraintlayout.widget.ConstraintLayout>