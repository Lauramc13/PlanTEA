<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_weight="1"
    android:background="?colorBG1"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/shapeableImageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        android:layout_margin="60dp"
        android:background="@drawable/mesh_gradient"
        android:scaleType="centerInside"
        android:adjustViewBounds="true"
        android:alpha="0.8"
        app:shapeAppearance="@style/Circular2"
        tools:layout_editor_absoluteX="100dp"
        tools:layout_editor_absoluteY="100dp" />

    <ImageView
        android:id="@+id/icono_CerrarDialogo"
        android:layout_width="55dp"
        android:layout_height="45dp"
        android:contentDescription="Cerrar seccion"
        android:background="@drawable/bg_close_button"
        android:src="@drawable/svg_close"
        android:padding="12dp"
        android:alpha="0.9"
        android:layout_margin="20dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardViewReloj"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/transparent"
        app:cardCornerRadius="100dp"
        app:cardElevation="0dp"
        android:layout_marginBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imvCircularWithStroke"
            android:layout_width="180dp"
            android:layout_height="180dp"
            android:layout_gravity="center"
            android:background="@color/white"
            android:alpha="0.6"
            app:shapeAppearance="@style/Circular" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBar"
            style="@style/Widget.Material3.CircularProgressIndicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:progress="100"
            app:indicatorColor="@color/white"
            app:indicatorSize="250dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/textView19"
            app:trackColor="?colorPrimary"
            app:trackCornerRadius="23dp"
            app:trackThickness="23dp" />

        <TextView
            android:id="@+id/timerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="00:00"
            android:textColor="@color/md_theme_light_onSurface"
            android:textSize="27sp" />

    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        app:layout_constraintBottom_toBottomOf="@+id/shapeableImageView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cardViewReloj">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stopButton"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_gravity="center"
            android:elevation="0dp"
            android:enabled="true"
            android:backgroundTint="@color/whitish"
            app:icon="@drawable/svg_stop"
            app:iconGravity="textEnd"
            app:iconSize="25dp"
            app:iconTint="@color/darkGreen" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startButton"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_margin="10dp"
            android:clickable="false"
            android:elevation="0dp"
            android:enabled="true"
            app:icon="@drawable/svg_pause"
            app:iconGravity="textEnd"
            app:iconSize="29dp"
            android:backgroundTint="@color/whitish"
            app:iconTint="@color/darkGreen" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/refreshButton"
            style="@style/Widget.Material3.Button.IconButton.Filled"
            android:layout_width="65dp"
            android:layout_height="65dp"
            android:layout_gravity="center"
            android:elevation="0dp"
            android:enabled="true"
            app:icon="@drawable/svg_refresh"
            app:iconGravity="textEnd"
            app:iconSize="25dp"
            android:backgroundTint="@color/whitish"
            app:iconTint="@color/darkGreen" />

    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>